<style>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

  :root {
    --brand:       #0284c7;
    --brand-dark:  #0369a1;
    --brand-light: #e0f2fe;
    --brand-50:    #f0f9ff;
    --green:       #16a34a;
    --green-bg:    #dcfce7;
    --amber:       #d97706;
    --amber-bg:    #fef3c7;
    --red:         #dc2626;
    --red-bg:      #fee2e2;
    --slate-50:    #f8fafc;
    --slate-100:   #f1f5f9;
    --slate-200:   #e2e8f0;
    --slate-300:   #cbd5e1;
    --slate-400:   #94a3b8;
    --slate-500:   #64748b;
    --slate-600:   #475569;
    --slate-700:   #334155;
    --slate-800:   #1e293b;
    --slate-900:   #0f172a;
    --white:       #ffffff;
    --radius-xs:   6px;
    --radius-sm:   10px;
    --radius-md:   14px;
    --radius-lg:   20px;
    --shadow-sm:   0 1px 3px rgba(15,23,42,.07),0 1px 2px rgba(15,23,42,.05);
    --shadow-md:   0 4px 16px rgba(15,23,42,.08),0 2px 6px rgba(15,23,42,.05);
  }

  .ap-wrap * { box-sizing: border-box; margin: 0; padding: 0; }
  .ap-wrap {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: var(--slate-100);
    min-height: 80vh;
    padding-bottom: 80px;
    color: var(--slate-800);
    font-size: 14px;
  }

  /* HERO */
  .ap-hero {
    background: linear-gradient(120deg, #0c1a2e 0%, #0369a1 60%, #0ea5e9 100%);
    padding: 40px 24px 90px;
    position: relative;
    overflow: hidden;
  }
  .ap-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 10% 80%, rgba(14,165,233,.22) 0%, transparent 50%),
      radial-gradient(ellipse at 85% 10%, rgba(56,189,248,.15) 0%, transparent 45%);
    pointer-events: none;
  }
  .ap-hero::before {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    right: -80px; top: -140px;
    border-radius: 50%;
    border: 60px solid rgba(255,255,255,.04);
    pointer-events: none;
  }
  .ap-hero-content {
    position: relative;
    z-index: 1;
    max-width: 1180px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .ap-avatar-ring {
    width: 78px; height: 78px;
    border-radius: 50%;
    background: rgba(255,255,255,.14);
    border: 2.5px solid rgba(255,255,255,.3);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    backdrop-filter: blur(10px);
  }
  .ap-avatar-ring svg { width: 34px; height: 34px; stroke: #fff; }
  .ap-hero-text { flex: 1; }
  .ap-hero-text h1 {
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 800;
    color: #fff;
    letter-spacing: -.02em;
    line-height: 1.2;
  }
  .ap-hero-email { color: rgba(255,255,255,.6); font-size: 13px; margin-top: 4px; }
  .ap-hero-meta { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; }
  .ap-hero-chip {
    display: inline-flex; align-items: center; gap: 5px;
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.18);
    border-radius: 100px;
    padding: 4px 12px;
    font-size: 11.5px; font-weight: 600;
    color: rgba(255,255,255,.85);
    backdrop-filter: blur(6px);
  }
  .ap-hero-chip svg { width: 12px; height: 12px; stroke: currentColor; }
  .ap-logout-btn {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: var(--radius-sm);
    padding: 8px 16px;
    color: rgba(255,255,255,.8);
    font-size: 12.5px; font-weight: 600;
    text-decoration: none;
    transition: all .2s;
    backdrop-filter: blur(6px);
    white-space: nowrap; flex-shrink: 0;
  }
  .ap-logout-btn:hover { background: rgba(255,255,255,.18); color: #fff; }

  /* QUICK NAV */
  .ap-quicknav {
    background: var(--white);
    border-bottom: 1px solid var(--slate-200);
    position: sticky; top: 0; z-index: 50;
    box-shadow: var(--shadow-sm);
  }
  .ap-quicknav-inner {
    max-width: 1180px; margin: 0 auto;
    display: flex; overflow-x: auto; scrollbar-width: none;
  }
  .ap-quicknav-inner::-webkit-scrollbar { display: none; }
  .ap-qn-item {
    display: flex; align-items: center; gap: 7px;
    padding: 14px 20px;
    font-size: 12.5px; font-weight: 600;
    color: var(--slate-500);
    text-decoration: none;
    border-bottom: 2.5px solid transparent;
    white-space: nowrap;
    transition: all .2s;
  }
  .ap-qn-item svg { width: 15px; height: 15px; stroke: currentColor; }
  .ap-qn-item:hover, .ap-qn-item.active { color: var(--brand); border-bottom-color: var(--brand); }

  /* MAIN LAYOUT */
  .ap-main {
    max-width: 1180px;
    margin: -46px auto 0;
    padding: 0 16px;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 20px;
    position: relative; z-index: 2;
  }

  /* CARDS */
  .ap-sidebar { display: flex; flex-direction: column; gap: 16px; }
  .ap-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--slate-200);
    overflow: hidden;
  }
  .ap-card-head {
    display: flex; align-items: center; gap: 9px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--slate-100);
  }
  .ap-card-head-icon {
    width: 30px; height: 30px;
    background: var(--brand-50);
    border-radius: var(--radius-xs);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .ap-card-head-icon svg { width: 14px; height: 14px; stroke: var(--brand); }
  .ap-card-head h3 { font-size: 13.5px; font-weight: 700; color: var(--slate-900); }
  .ap-card-body { padding: 18px 20px; }

  /* PROFILE SIDEBAR */
  .ap-profile-row { display: flex; flex-direction: column; gap: 12px; }
  .ap-profile-field { display: flex; flex-direction: column; gap: 3px; }
  .ap-profile-label {
    font-size: 10px; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase; color: var(--slate-400);
  }
  .ap-profile-value { font-size: 13.5px; font-weight: 600; color: var(--slate-800); word-break: break-word; }
  .ap-profile-value.muted { color: var(--slate-400); font-weight: 400; font-style: italic; }
  .ap-divider { height: 1px; background: var(--slate-100); margin: 4px 0; }

  /* STATS */
  .ap-stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .ap-stat-box {
    background: var(--slate-50);
    border: 1px solid var(--slate-200);
    border-radius: var(--radius-sm);
    padding: 12px; text-align: center;
  }
  .ap-stat-num { font-size: 22px; font-weight: 800; color: var(--brand); line-height: 1; }
  .ap-stat-lbl { font-size: 10.5px; color: var(--slate-500); font-weight: 500; margin-top: 4px; }

  /* SIDEBAR NAV */
  .ap-sidenav { display: flex; flex-direction: column; }
  .ap-sidenav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 11px 20px;
    font-size: 13px; font-weight: 500;
    color: var(--slate-600);
    text-decoration: none;
    border-left: 3px solid transparent;
    transition: all .15s;
  }
  .ap-sidenav-item svg { width: 15px; height: 15px; stroke: currentColor; flex-shrink: 0; }
  .ap-sidenav-item:hover { background: var(--brand-50); color: var(--brand); border-left-color: var(--brand); }
  .ap-sidenav-item + .ap-sidenav-item { border-top: 1px solid var(--slate-100); }

  /* CONTENT */
  .ap-content { display: flex; flex-direction: column; gap: 20px; }
  .ap-section-title { font-size: 15px; font-weight: 800; color: var(--slate-900); letter-spacing: -.02em; }
  .ap-section-sub { font-size: 12px; color: var(--slate-400); margin-top: 2px; }

  /* TABLE */
  .ap-table-wrap { overflow-x: auto; }
  .ap-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .ap-table thead th {
    text-align: left; padding: 10px 16px;
    font-size: 10px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase;
    color: var(--slate-400); background: var(--slate-50);
    border-bottom: 1px solid var(--slate-200); white-space: nowrap;
  }
  .ap-table tbody tr { border-bottom: 1px solid var(--slate-100); transition: background .15s; }
  .ap-table tbody tr:last-child { border-bottom: none; }
  .ap-table tbody tr:hover { background: var(--brand-50); }
  .ap-table td { padding: 13px 16px; color: var(--slate-700); vertical-align: middle; }
  .ap-order-num {
    display: inline-flex; align-items: center; gap: 5px;
    font-weight: 700; color: var(--brand); text-decoration: none; font-size: 12.5px;
    padding: 4px 10px; background: var(--brand-light);
    border: 1px solid #bae6fd; border-radius: var(--radius-xs); transition: all .15s;
  }
  .ap-order-num:hover { background: #bae6fd; }
  .ap-price { font-weight: 700; color: var(--slate-900); }

  /* BADGES */
  .ap-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 9px; border-radius: 100px;
    font-size: 11px; font-weight: 700; white-space: nowrap;
  }
  .ap-badge::before {
    content: ''; width: 5px; height: 5px; border-radius: 50%;
    background: currentColor; opacity: .7; flex-shrink: 0;
  }
  .ap-badge-green   { background: var(--green-bg);  color: var(--green); }
  .ap-badge-amber   { background: var(--amber-bg);  color: var(--amber); }
  .ap-badge-red     { background: var(--red-bg);    color: var(--red); }
  .ap-badge-blue    { background: var(--brand-light); color: var(--brand-dark); }
  .ap-badge-default { background: var(--slate-100); color: var(--slate-500); }

  /* EMPTY */
  .ap-empty { text-align: center; padding: 52px 24px; }
  .ap-empty-icon {
    width: 60px; height: 60px; background: var(--brand-50); border-radius: 50%;
    display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;
  }
  .ap-empty-icon svg { width: 26px; height: 26px; stroke: var(--brand); }
  .ap-empty h4 { font-size: 15px; font-weight: 700; color: var(--slate-800); margin-bottom: 6px; }
  .ap-empty p  { font-size: 13px; color: var(--slate-400); line-height: 1.6; }
  .ap-cta-btn {
    display: inline-flex; align-items: center; gap: 7px;
    margin-top: 16px; background: var(--brand); color: var(--white);
    padding: 10px 20px; border-radius: var(--radius-sm);
    font-size: 13px; font-weight: 600; text-decoration: none; transition: background .2s;
  }
  .ap-cta-btn:hover { background: var(--brand-dark); }

  /* ADDRESS GRID */
  .ap-addr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .ap-addr-box {
    border: 1.5px solid var(--slate-200); border-radius: var(--radius-md);
    padding: 16px; position: relative; transition: border-color .2s, box-shadow .2s;
  }
  .ap-addr-box:hover { border-color: var(--brand); box-shadow: 0 0 0 3px rgba(2,132,199,.08); }
  .ap-addr-box.default-addr { border-color: var(--brand); background: var(--brand-50); }
  .ap-addr-default-tag {
    position: absolute; top: -1px; right: 14px;
    background: var(--brand); color: #fff;
    font-size: 9.5px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
    padding: 3px 9px; border-radius: 0 0 6px 6px;
  }
  .ap-addr-name { font-size: 13.5px; font-weight: 700; color: var(--slate-900); margin-bottom: 6px; }
  .ap-addr-detail { font-size: 12.5px; color: var(--slate-500); line-height: 1.7; }
  .ap-addr-actions { display: flex; gap: 8px; margin-top: 12px; }
  .ap-addr-action-btn {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11.5px; font-weight: 600; color: var(--brand);
    text-decoration: none; padding: 4px 10px;
    border: 1px solid var(--brand-light); border-radius: var(--radius-xs);
    background: var(--brand-50); transition: all .15s;
  }
  .ap-addr-action-btn:hover { background: var(--brand-light); }
  .ap-addr-action-btn svg { width: 11px; height: 11px; stroke: currentColor; }

  /* INFO ROWS */
  .ap-info-rows { display: flex; flex-direction: column; }
  .ap-info-row {
    display: flex; align-items: flex-start; justify-content: space-between;
    padding: 13px 0; border-bottom: 1px solid var(--slate-100); gap: 12px;
  }
  .ap-info-row:last-child { border-bottom: none; }
  .ap-info-row-left { display: flex; align-items: center; gap: 10px; }
  .ap-info-icon {
    width: 32px; height: 32px; background: var(--slate-50);
    border-radius: var(--radius-xs); display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; border: 1px solid var(--slate-200);
  }
  .ap-info-icon svg { width: 14px; height: 14px; stroke: var(--slate-500); }
  .ap-info-key { font-size: 12px; font-weight: 600; color: var(--slate-500); }
  .ap-info-val { font-size: 13.5px; font-weight: 600; color: var(--slate-900); margin-top: 1px; }
  .ap-info-val.muted { color: var(--slate-400); font-style: italic; font-weight: 400; }
  .ap-edit-link {
    font-size: 11.5px; font-weight: 700; color: var(--brand); text-decoration: none;
    white-space: nowrap; padding: 4px 10px;
    border: 1px solid var(--brand-light); border-radius: var(--radius-xs);
    background: var(--brand-50); transition: all .15s; flex-shrink: 0;
  }
  .ap-edit-link:hover { background: var(--brand-light); }

  /* SECURITY */
  .ap-security-rows { display: flex; flex-direction: column; }
  .ap-security-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 13px 0; border-bottom: 1px solid var(--slate-100); gap: 12px;
  }
  .ap-security-row:last-child { border-bottom: none; }
  .ap-security-left { display: flex; align-items: center; gap: 10px; }
  .ap-security-icon {
    width: 32px; height: 32px; border-radius: var(--radius-xs);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .ap-security-icon.ok   { background: var(--green-bg); }
  .ap-security-icon.ok svg { stroke: var(--green); }
  .ap-security-icon.warn { background: var(--amber-bg); }
  .ap-security-icon.warn svg { stroke: var(--amber); }
  .ap-security-icon svg { width: 15px; height: 15px; }
  .ap-security-lbl { font-size: 13px; font-weight: 600; color: var(--slate-800); }
  .ap-security-sub { font-size: 11px; color: var(--slate-400); margin-top: 2px; }
  .ap-sec-btn {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 11.5px; font-weight: 700; color: var(--brand); text-decoration: none;
    padding: 5px 12px; border: 1px solid var(--brand-light); border-radius: var(--radius-xs);
    background: var(--brand-50); transition: all .15s; white-space: nowrap; flex-shrink: 0;
  }
  .ap-sec-btn:hover { background: var(--brand-light); }

  /* NOTIFICATIONS */
  .ap-notif-rows { display: flex; flex-direction: column; }
  .ap-notif-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 0; border-bottom: 1px solid var(--slate-100);
  }
  .ap-notif-row:last-child { border-bottom: none; }
  .ap-notif-left { display: flex; align-items: center; gap: 10px; }
  .ap-notif-icon {
    width: 30px; height: 30px; border-radius: var(--radius-xs);
    display: flex; align-items: center; justify-content: center;
    background: var(--slate-50); border: 1px solid var(--slate-200);
  }
  .ap-notif-icon svg { width: 14px; height: 14px; stroke: var(--slate-400); }
  .ap-notif-lbl { font-size: 13px; font-weight: 600; color: var(--slate-700); }
  .ap-notif-sub { font-size: 11px; color: var(--slate-400); margin-top: 1px; }
  .ap-toggle {
    width: 40px; height: 22px; background: var(--slate-200); border-radius: 100px;
    position: relative; cursor: pointer; transition: background .2s;
    flex-shrink: 0; border: none;
  }
  .ap-toggle.on { background: var(--brand); }
  .ap-toggle::after {
    content: ''; position: absolute;
    width: 16px; height: 16px; background: #fff; border-radius: 50%;
    top: 3px; left: 3px; transition: left .2s;
    box-shadow: 0 1px 3px rgba(0,0,0,.2);
  }
  .ap-toggle.on::after { left: 21px; }

  /* PAGINATION */
  .ap-pagination { padding: 14px 20px; border-top: 1px solid var(--slate-100); }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .ap-main { grid-template-columns: 1fr; margin-top: -24px; }
    .ap-sidebar { flex-direction: row; flex-wrap: wrap; }
    .ap-sidebar .ap-card { flex: 1; min-width: 240px; }
    .ap-addr-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .ap-hero { padding: 30px 16px 70px; }
    .ap-hero-content { flex-wrap: wrap; }
    .ap-logout-btn { width: 100%; justify-content: center; }
    .ap-table thead { display: none; }
    .ap-table td {
      display: flex; justify-content: space-between; align-items: center;
      padding: 9px 14px; font-size: 12.5px;
    }
    .ap-table td::before {
      content: attr(data-label);
      font-weight: 700; font-size: 10px; letter-spacing: .06em;
      text-transform: uppercase; color: var(--slate-400);
      flex-shrink: 0; margin-right: 10px;
    }
    .ap-table tr {
      display: block; border: 1px solid var(--slate-200);
      border-radius: var(--radius-md); margin-bottom: 10px; overflow: hidden;
    }
    .ap-table tbody { display: block; padding: 14px; }

/* UPDATED FOOTER ICON FIX */
.site-footer img, 
.site-footer svg,
.payment-icons-list img,
.payment-icons-list svg {
  opacity: 1 !important;
  filter: none !important;
  /* We removed "fill" and "color" here so original brand colors show through */
}

/* Only apply color to social icons if they are simple paths */
.social-icons-row a svg {
  fill: currentColor !important; 
}
</style>

<div class="ap-wrap">

  <!-- HERO -->
  <div class="ap-hero">
    <div class="ap-hero-content">
      <div class="ap-avatar-ring">
        <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
        </svg>
      </div>
      <div class="ap-hero-text">
        <h1>{{ customer.first_name | default: 'My' }} {{ customer.last_name | default: 'Account' }}</h1>
        <div class="ap-hero-email">{{ customer.email }}</div>
        <div class="ap-hero-meta">
          <span class="ap-hero-chip">
            <svg fill="none" viewBox="0 0 24 24" stroke-width="2" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007Z"/></svg>
            {{ customer.orders_count }} Order{% if customer.orders_count != 1 %}s{% endif %}
          </span>
          <span class="ap-hero-chip">
            <svg fill="none" viewBox="0 0 24 24" stroke-width="2" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
            {{ customer.addresses_count }} Address{% if customer.addresses_count != 1 %}es{% endif %}
          </span>
          <span class="ap-hero-chip">
            <svg fill="none" viewBox="0 0 24 24" stroke-width="2" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/></svg>
            Verified Member
          </span>
        </div>
      </div>
      {{ 'layout.customer.log_out' | t | customer_logout_link | replace: '<a ', '<a class="ap-logout-btn" ' }}
    </div>
  </div>

  <!-- QUICK NAV -->
  <div class="ap-quicknav">
    <div class="ap-quicknav-inner">
