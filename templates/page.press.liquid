<style>
/* Reset / Flush */
#MainContent { padding-top: 0 !important; margin-top: 0 !important; }

/* ================================================================
   DESIGN TOKENS
   ================================================================ */
:root {
  --np-dark:    #06263a;
  --np-primary: #0A4D68;
  --np-mid:     #088395;
  --np-accent:  #05b8cc;
  --np-light:   #e8f7fb;
  --np-bg:      #f4f8fb;
  --np-white:   #ffffff;
  --np-text:    #2d4a54;
  --np-muted:   #6b8fa0;
  --np-radius:  16px;
  --np-shadow:  0 8px 40px rgba(10,77,104,0.12);
  --np-glow:    0 0 40px rgba(5,184,204,0.25);
  --np-ease:    cubic-bezier(0.4, 0, 0.2, 1);
  --np-spring:  cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ================================================================
   HERO
   ================================================================ */
.np-hero {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #06263a 0%, #0A4D68 45%, #088395 75%, #05b8cc 100%);
  background-size: 300% 300%;
  animation: np-hero-shift 14s ease infinite;
  padding: 60px 0 40px;
  text-align: center;
}

@keyframes np-hero-shift {
  0%   { background-position: 0% 50%; }
  50%  { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* Orbs */
.np-hero__orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  pointer-events: none;
}
.np-hero__orb--a {
  width: 560px; height: 560px;
  background: rgba(5,184,204,0.3);
  top: -200px; right: -140px;
  animation: np-orb-a 12s ease-in-out infinite;
}
.np-hero__orb--b {
  width: 400px; height: 400px;
  background: rgba(8,131,149,0.28);
  bottom: -160px; left: -80px;
  animation: np-orb-b 15s ease-in-out infinite;
}
.np-hero__orb--c {
  width: 260px; height: 260px;
  background: rgba(0,255,202,0.18);
  top: 30%; left: 50%;
  transform: translateX(-50%);
  animation: np-orb-c 9s ease-in-out infinite;
}
@keyframes np-orb-a {
  0%,100% { transform: translate(0,0) scale(1); }
  50%      { transform: translate(-50px,40px) scale(1.1); }
}
@keyframes np-orb-b {
  0%,100% { transform: translate(0,0) scale(1); }
  50%      { transform: translate(40px,-30px) scale(0.95); }
}
@keyframes np-orb-c {
  0%,100% { transform: translateX(-50%) scale(1); opacity: 0.6; }
  50%      { transform: translateX(-50%) scale(1.3); opacity: 0.3; }
}

/* Particles */
.np-hero__particles { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
.np-hero__particles span {
  position: absolute;
  width: 4px; height: 4px;
  background: rgba(255,255,255,0.45);
  border-radius: 50%;
  animation: np-particle 8s ease-in-out infinite;
}
.np-hero__particles span:nth-child(1)  { top:15%; left:10%; animation-delay:0s;    animation-duration:7s; }
.np-hero__particles span:nth-child(2)  { top:70%; left:20%; animation-delay:-2s;   animation-duration:9s; }
.np-hero__particles span:nth-child(3)  { top:30%; left:80%; animation-delay:-4s;   animation-duration:6s; }
.np-hero__particles span:nth-child(4)  { top:85%; left:70%; animation-delay:-1s;   animation-duration:10s; }
.np-hero__particles span:nth-child(5)  { top:50%; left:50%; animation-delay:-3s;   animation-duration:8s; width:6px; height:6px; }
.np-hero__particles span:nth-child(6)  { top:20%; left:45%; animation-delay:-5s;   animation-duration:7s; }
.np-hero__particles span:nth-child(7)  { top:60%; left:5%;  animation-delay:-0.5s; animation-duration:11s; }
.np-hero__particles span:nth-child(8)  { top:10%; left:90%; animation-delay:-6s;   animation-duration:8s; }
@keyframes np-particle {
  0%,100% { transform: translateY(0) scale(1);   opacity: 0.5; }
  50%      { transform: translateY(-20px) scale(1.4); opacity: 1; }
}

.np-hero__inner {
  position: relative;
  z-index: 2;
}

.np-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.22);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  color: rgba(255,255,255,0.95);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.04em;
  padding: 10px 22px;
  border-radius: 100px;
  margin-bottom: 32px;
  animation: np-fade-up 0.7s var(--np-ease) 0.1s both;
}
.np-hero__badge svg { color: #FFD700; flex-shrink: 0; }

.np-hero__heading {
  font-size: clamp(2.4rem, 7vw, 4.4rem);
  font-weight: 900;
  color: #fff;
  line-height: 1.05;
  letter-spacing: -0.035em;
  margin: 0 0 20px;
  animation: np-fade-up 0.7s var(--np-ease) 0.25s both;
}
.np-hero__heading-accent {
  background: linear-gradient(135deg, #05b8cc, #00FFCA);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.np-hero__sub {
  font-size: clamp(1rem, 2.5vw, 1.2rem);
  color: rgba(255,255,255,0.8);
  max-width: 600px;
  margin: 0 auto 48px;
  line-height: 1.75;
  animation: np-fade-up 0.7s var(--np-ease) 0.4s both;
}

/* Hero stats */
.np-hero__stats {
  display: inline-flex;
  align-items: center;
  gap: 0;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.18);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 100px;
  padding: 16px 36px;
  animation: np-fade-up 0.7s var(--np-ease) 0.55s both;
}
.np-hero__stat { text-align: center; padding: 0 24px; }
.np-hero__stat-num {
  display: inline-block;
  font-size: 1.8rem;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  letter-spacing: -0.02em;
}
.np-hero__stat-plus { font-size: 1.4rem; font-weight: 900; color: #05b8cc; }
.np-hero__stat-label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  color: rgba(255,255,255,0.65);
  text-transform: none;
  letter-spacing: 0.08em;
  margin-top: 4px;
}
.np-hero__stat-divider {
  width: 1px; height: 44px;
  background: rgba(255,255,255,0.2);
  flex-shrink: 0;
}

/* Wave */
.np-hero__wave {
  position: absolute; bottom: -1px; left: 0; right: 0;
  line-height: 0; pointer-events: none;
}
.np-hero__wave svg { display: block; width: 100%; height: 80px; }

/* ================================================================
   SECTION COMMON
   ================================================================ */
.np-section {
  padding: 96px 0 104px;
  background: var(--np-bg);
}
.np-section--articles {
  background: var(--np-white);
}

.np-section__header { text-align: center; margin-bottom: 64px; }
.np-eyebrow {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
