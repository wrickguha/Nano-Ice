<!-- ================================================================
     SCRIPTS
     ================================================================ -->
<script>
(function () {
  'use strict';

  /* Lightbox */
  var lb     = document.getElementById('np-lightbox');
  var lbVid  = document.getElementById('np-lightbox-video');

  function openLb(videoId) {
    if (!lb || !lbVid || !videoId) return;
    lbVid.innerHTML =
      '<iframe src="https://www.youtube-nocookie.com/embed/' +
      encodeURIComponent(videoId) +
      '?autoplay=1&rel=0&modestbranding=1" allow="autoplay; encrypted-media" allowfullscreen></iframe>';
    lb.classList.add('np-lightbox--open');
    document.body.style.overflow = 'hidden';
    lb.querySelector('.np-lightbox__close').focus();
  }

  function closeLb() {
    if (!lb) return;
    lb.classList.remove('np-lightbox--open');
    document.body.style.overflow = '';
    setTimeout(function () { if (lbVid) lbVid.innerHTML = ''; }, 400);
  }

  if (lb) {
    lb.querySelector('.np-lightbox__backdrop').addEventListener('click', closeLb);
    lb.querySelector('.np-lightbox__close').addEventListener('click', closeLb);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && lb.classList.contains('np-lightbox--open')) closeLb();
    });
  }

  /* Play buttons */
  document.querySelectorAll('.np-play-btn').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var media = btn.closest('.np-video-card__media');
      if (media) openLb(media.getAttribute('data-video-id'));
    });
  });

  /* Watch Now body buttons */
  document.querySelectorAll('.np-video-card__btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      openLb(btn.getAttribute('data-video-id'));
    });
  });

  /* Click anywhere on thumbnail */
  document.querySelectorAll('.np-video-card__media').forEach(function (el) {
    el.addEventListener('click', function (e) {
      if (e.target.closest('.np-play-btn')) return;
      openLb(el.getAttribute('data-video-id'));
    });
  });

  /* Counter animation */
  function animateCount(el, target, duration) {
    var start = 0;
    var step = target / (duration / 16);
    var interval = setInterval(function () {
      start += step;
      if (start >= target) {
        el.textContent = target;
        clearInterval(interval);
      } else {
        el.textContent = Math.floor(start);
      }
    }, 16);
  }

  /* Scroll Reveal */
  var countersTriggered = false;
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('np-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.np-reveal').forEach(function (el) {
    observer.observe(el);
  });

  /* Counter observer */
  var heroStats = document.querySelector('.np-hero__stats');
  if (heroStats) {
    var counterObs = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting && !countersTriggered) {
        countersTriggered = true;
        document.querySelectorAll('.np-hero__stat-num').forEach(function (el) {
          animateCount(el, parseInt(el.getAttribute('data-target'), 10), 1200);
        });
        counterObs.disconnect();
      }
    }, { threshold: 0.5 });
    counterObs.observe(heroStats);
  }

  /* Mobile Carousel */
  var grid     = document.getElementById('np-video-grid');
  var dotsWrap = document.getElementById('np-carousel-dots');
  var nav      = document.getElementById('np-carousel-nav');
  var current  = 0;

  function isMobile() { return window.innerWidth <= 768; }
  function getCards() { return grid ? Array.prototype.slice.call(grid.querySelectorAll('.np-video-card')) : []; }

  function buildDots() {
    if (!dotsWrap) return;
    dotsWrap.innerHTML = '';
    if (!isMobile()) return;
    getCards().forEach(function (_, i) {
      var dot = document.createElement('button');
      dot.className = 'np-carousel-dot' + (i === current ? ' np-carousel-dot--active' : '');
      dot.setAttribute('aria-label', 'Video ' + (i + 1));
      dot.addEventListener('click', function () { goTo(i); });
      dotsWrap.appendChild(dot);
    });
  }

  function syncDots() {
    if (!dotsWrap) return;
    dotsWrap.querySelectorAll('.np-carousel-dot').forEach(function (d, i) {
      d.classList.toggle('np-carousel-dot--active', i === current);
    });
  }

  function goTo(index) {
    var c = getCards();
    if (!c.length || !grid) return;
    current = Math.max(0, Math.min(index, c.length - 1));
    var card = c[current];
    var scrollLeft = card.offsetLeft - (grid.offsetWidth - card.offsetWidth) / 2;
    grid.scrollTo({ left: scrollLeft, behavior: 'smooth' });
    syncDots();
  }

  if (grid) {
    var scrollTimer;
    grid.addEventListener('scroll', function () {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function () {
        if (!isMobile()) return;
        var mid = grid.scrollLeft + grid.offsetWidth / 2;
        var best = 0, bestDist = Infinity;
        getCards().forEach(function (c, i) {
          var d = Math.abs(c.offsetLeft + c.offsetWidth / 2 - mid);
          if (d < bestDist) { bestDist = d; best = i; }
        });
        current = best;
        syncDots();
      }, 60);
    }, { passive: true });
  }

  if (nav) {
    nav.querySelector('.np-carousel-btn--prev').addEventListener('click', function () { goTo(current - 1); });
    nav.querySelector('.np-carousel-btn--next').addEventListener('click', function () { goTo(current + 1); });
  }

  buildDots();
  window.addEventListener('resize', buildDots);

})();
</script>
