{{ 'video-testimonials.css' | asset_url | stylesheet_tag }}

<div class="press-page">

  <!-- Hero -->
  <div class="press-page__hero">
    <h1 class="press-page__hero-title">Press &amp; Media</h1>
    <p class="press-page__hero-sub">Nano-Ice has been featured in leading news outlets across Boston and beyond.</p>
  </div>

  <div class="page-width press-page__content">

    <!-- VIDEO FEATURES -->
    <section class="press-section">
      <h2 class="press-section__heading">Video Features</h2>

      <div class="vtg-grid press-vtg-grid" id="press-vtg-grid">

        <!-- 1. Press Overview -->
        <div class="vtg-card">
          <div class="vtg-card__video-wrap">
            <div class="vtg-card__video-placeholder" data-video-type="youtube" data-video-id="XOu4J0Mt6uw">
              <img src="https://img.youtube.com/vi/XOu4J0Mt6uw/maxresdefault.jpg"
                   onerror="this.src='https://img.youtube.com/vi/XOu4J0Mt6uw/hqdefault.jpg'"
                   alt="Press Overview — Nano-Ice" class="vtg-card__thumbnail" loading="lazy">
              <button class="vtg-card__play-btn press-play-btn" aria-label="Play Press Overview video">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </button>
            </div>
          </div>
          <div class="vtg-card__content">
            <div class="press-vtg-outlet-badge">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
              Press Overview
            </div>
            <blockquote class="vtg-card__quote">"The hottest look for the summer"</blockquote>
            <div class="vtg-card__author">
              <span class="vtg-card__name">WCVB 5 · FOX 13 · More</span>
              <span class="vtg-card__location">Multiple Networks</span>
            </div>
          </div>
        </div>

        <!-- 2. ABC Boston -->
        <div class="vtg-card">
          <div class="vtg-card__video-wrap">
            <div class="vtg-card__video-placeholder" data-video-type="youtube" data-video-id="loEmjYsA0ZQ">
              <img src="https://img.youtube.com/vi/loEmjYsA0ZQ/maxresdefault.jpg"
                   onerror="this.src='https://img.youtube.com/vi/loEmjYsA0ZQ/hqdefault.jpg'"
                   alt="ABC Boston — Nano-Ice Feature" class="vtg-card__thumbnail" loading="lazy">
              <button class="vtg-card__play-btn press-play-btn" aria-label="Play ABC Boston video">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </button>
            </div>
          </div>
          <div class="vtg-card__content">
            <div class="press-vtg-outlet-badge">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
              ABC Boston
            </div>
            <blockquote class="vtg-card__quote">"Brookline couple designs cooling necklaces to beat summer heat"</blockquote>
            <div class="vtg-card__author">
              <span class="vtg-card__name">ABC Boston</span>
              <span class="vtg-card__location">News Feature</span>
            </div>
          </div>
        </div>

        <!-- 3. MSNBC -->
