          <div class="vtg-card__video-wrap">
            <div class="vtg-card__video-placeholder" data-video-type="youtube" data-video-id="Hro_8FFs1Lw">
              <img src="https://img.youtube.com/vi/Hro_8FFs1Lw/maxresdefault.jpg"
