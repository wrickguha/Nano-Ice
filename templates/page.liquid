    } else {
      if (v.thumb) el.style.backgroundImage = 'url(' + v.thumb + ')';

      var ov = document.createElement('div');
      ov.className = 'nitv-panel-overlay';
      el.appendChild(ov);

      var lbl = document.createElement('span');
      lbl.className = 'nitv-panel-name';
      lbl.textContent = v.name;
      el.appendChild(lbl);

      el.addEventListener('click', (function (i) {
        return function () { current = i; render(); };
      }(vi)));
    }
    return el;
  }

  function renderDots() {
    dotsEl.innerHTML = '';
    for (var i = 0; i < n; i++) {
      var dot = document.createElement('button');
      dot.className = 'nitv-dot' + (i === current ? ' is-active' : '');
      dot.setAttribute('aria-label', 'Video ' + (i + 1));
      dot.addEventListener('click', (function (i) {
        return function () { current = i; render(); };
      }(i)));
      dotsEl.appendChild(dot);
    }
  }

  prevBtn.addEventListener('click', function () { current = idx(-1); render(); });
  nextBtn.addEventListener('click', function () { current = idx(1);  render(); });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  { current = idx(-1); render(); }
    if (e.key === 'ArrowRight') { current = idx(1);  render(); }
  });

  render();

  // Remove video iframes from the below-content section
  var belowRte = document.getElementById('press-below-rte');
  if (belowRte) {
    belowRte.querySelectorAll('iframe').forEach(function (el) {
      var wrapper = el.closest('p, div, .video-wrapper') || el;
      if (wrapper.parentNode) wrapper.parentNode.removeChild(wrapper);
    });
  }
}());
</script>

{% else %}

<div class="page-width">
  <div class="grid">
    <div class="grid__item medium-up--five-sixths medium-up--push-one-twelfth">
      <div class="section-header text-center">
        <h1>{{ page.title }}</h1>
      </div>

      <div class="rte">
        {{ page.content }}
      </div>
    </div>
  </div>
</div>

{% endif %}
