<script>
(function () {
  var rte = document.querySelector('.rte');
  if (!rte) return;

  // Find "What's Unique" heading inside .rte
  var headings = rte.querySelectorAll('h1, h2, h3, h4, h5, h6');
  var target = null;
  for (var i = 0; i < headings.length; i++) {
    if (headings[i].textContent.toLowerCase().indexOf('what') !== -1 &&
        headings[i].textContent.toLowerCase().indexOf('unique') !== -1) {
      target = headings[i];
      break;
    }
  }

  if (!target) return;

  // Collect all nodes from "What's Unique" to end of .rte
  var nodesToMove = [];
  var node = target;
  while (node) {
    nodesToMove.push(node);
    node = node.nextSibling;
  }

  // Find the outer .page-width wrapping the .rte
  var outerPageWidth = rte.closest ? rte.closest('.page-width') : (function () {
    var el = rte;
    while (el && !el.classList.contains('page-width')) el = el.parentNode;
    return el;
  }());
  if (!outerPageWidth) return;

  // Re-create the same grid/item/rte structure for the content below mission
  var belowRte  = document.createElement('div');
  belowRte.className = 'rte';
  nodesToMove.forEach(function (n) { belowRte.appendChild(n); });

  var belowItem = document.createElement('div');
  belowItem.className = 'grid__item medium-up--five-sixths medium-up--push-one-twelfth';
  belowItem.appendChild(belowRte);

  var belowGrid = document.createElement('div');
  belowGrid.className = 'grid';
  belowGrid.appendChild(belowItem);

  var belowWrap = document.createElement('div');
  belowWrap.className = 'page-width';
  belowWrap.style.paddingTop = '48px';
  belowWrap.appendChild(belowGrid);

  // Mission block is already in the DOM after outerPageWidth — ensure correct order:
  // outerPageWidth → mission → belowWrap → cta
  var mission = document.getElementById('ni-mission-block');
  var parent  = outerPageWidth.parentNode;

  // Move mission to directly after outerPageWidth
  var afterOuter = outerPageWidth.nextSibling;
  if (mission) parent.insertBefore(mission, afterOuter);

  // Insert below-content after mission
  var afterMission = mission ? mission.nextSibling : afterOuter;
  parent.insertBefore(belowWrap, afterMission);

  // CTA already sits after belowWrap naturally
}());
</script>
