  flex: 0 0 46%;
  position: relative;
  background: #0a2030;
  min-height: 0;
}
.nau-video-card__media iframe {
  display: block;
  position: absolute;
  inset: 0;
  width: 100% !important;
  height: 100% !important;
  border: none;
}
.nau-video-card__media-sizer {
  padding-top: 56.25%;
}
.nau-video-card__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40px 44px;
}
.nau-video-card__body p {
  font-size: 1.025rem;
  line-height: 1.82;
  color: #2d4a54;
  margin: 0 0 1rem;
}
.nau-video-card__body p:last-child { margin-bottom: 0; }
.nau-video-card__body::before {
  content: '';
  display: block;
  width: 3px;
  height: 48px;
  border-radius: 2px;
  background: linear-gradient(180deg, #088395 0%, #05b8cc 100%);
  margin-bottom: 20px;
  flex-shrink: 0;
}

/* ── Standalone paragraphs ── */
.nau-story__rte > p {
  max-width: 760px;
  margin-left: auto;
  margin-right: auto;
  margin-bottom: 1.4rem;
}
.nau-story__rte > p:first-of-type {
  font-size: 1.15rem;
  font-weight: 500;
  color: #0A4D68;
  line-height: 1.75;
  text-align: center;
  padding-bottom: 32px;
  border-bottom: 1px solid rgba(8,131,149,0.14);
  margin-bottom: 44px;
}
.nau-story__rte > p:last-of-type {
  font-size: 1.05rem;
  text-align: center;
  font-style: italic;
  color: #088395;
  font-weight: 500;
  padding-top: 12px;
}

/* ── Headings ── */
.nau-story__rte h1,
.nau-story__rte h2,
.nau-story__rte h3,
.nau-story__rte h4 {
  font-family: 'Inter', Georgia, sans-serif;
  color: #0A4D68;
  letter-spacing: -0.025em;
  margin-top: 2.5rem;
  margin-bottom: 0.8rem;
  max-width: 760px;
  margin-left: auto;
  margin-right: auto;
}
.nau-story__rte h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; }
.nau-story__rte h3 { font-size: clamp(1.2rem, 2.5vw, 1.55rem); font-weight: 600; }
.nau-story__rte a  { color: #088395; text-decoration: underline; }
.nau-story__rte img {
  border-radius: 18px;
  box-shadow: 0 10px 48px rgba(10,77,104,0.13);
  max-width: 100%;
  height: auto;
  display: block;
  margin: 36px auto;
}
.nau-story__rte blockquote {
  border-left: 4px solid #088395;
  background: linear-gradient(100deg, #e8f7fb 0%, #f5fbfd 100%);
  border-radius: 0 14px 14px 0;
  padding: 22px 32px;
  margin: 36px auto;
  max-width: 760px;
  font-size: 1.1rem;
  font-style: italic;
  color: #0A4D68;
  font-weight: 500;
}

/* ── List items ── */
.nau-story__rte ul {
  list-style: none;
  padding: 0;
  margin: 0 auto 1.5rem;
  max-width: 760px;
}
.nau-story__rte ul li {
  padding: 14px 20px 14px 52px;
  position: relative;
  background: linear-gradient(100deg, #f4fbfd 0%, #eef8fa 100%);
  border: 1px solid rgba(8,131,149,0.10);
  border-radius: 10px;
  margin-bottom: 10px;
  font-size: 1rem;
  line-height: 1.7;
  color: #2d4a54;
}
.nau-story__rte ul li::before {
  content: '';
  position: absolute;
  left: 16px;
  top: 50%;
  transform: translateY(-50%);
  width: 18px; height: 18px;
  border-radius: 50%;
  background: linear-gradient(135deg, #088395 0%, #05b8cc 100%);
}

/* ================================================================
   MISSION
   ================================================================ */
.nau-mission {
  position: relative;
  overflow: hidden;
  background: linear-gradient(160deg, #0A4D68 0%, #065f77 50%, #088395 100%);
  padding: 96px 0 104px;
}
.nau-mission__orb {
  position: absolute;
  width: 600px; height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 68%);
  top: -130px; right: -130px;
  pointer-events: none;
}
.nau-mission__inner {
  position: relative;
  z-index: 1;
  max-width: 700px;
  margin: 0 auto;
  padding: 0 32px;
}
.nau-mission .nau-eyebrow { color: rgba(255,255,255,0.60); }
.nau-mission__heading {
  font-family: 'Inter', Georgia, sans-serif;
  font-size: clamp(2rem, 4.5vw, 3rem);
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.03em;
  line-height: 1.15;
  margin: 0 0 56px;
}
.nau-mission__timeline {
  display: flex;
  flex-direction: column;
}
.nau-mission__step {
  display: flex;
  align-items: flex-start;
  gap: 24px;
  padding-bottom: 40px;
  position: relative;
}
.nau-mission__step:not(.nau-mission__step--highlight)::after {
  content: '';
  position: absolute;
  left: 21px;
  top: 50px;
  bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.18), rgba(255,255,255,0.04));
}
.nau-mission__step--highlight { padding-bottom: 0; }
.nau-mission__icon {
  flex-shrink: 0;
  width: 44px; height: 44px;
  border-radius: 12px;
  background: rgba(255,255,255,0.10);
  border: 1.5px solid rgba(255,255,255,0.20);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.88);
  position: relative;
  z-index: 1;
  transition: transform 0.25s ease;
}
.nau-mission__icon--accent {
  background: rgba(5,184,204,0.22);
  border-color: rgba(5,184,204,0.40);
  color: #05b8cc;
}
.nau-mission__step:hover .nau-mission__icon { transform: scale(1.12); }
.nau-mission__step-body p {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.82);
  line-height: 1.75;
  margin: 10px 0 0;
}
.nau-mission__step--highlight .nau-mission__step-body p {
  font-size: 1.12rem;
  font-weight: 600;
  color: #ffffff;
  font-style: italic;
}

/* ================================================================
   IMPACT STATS
   ================================================================ */
.nau-stats {
  background: linear-gradient(135deg, #065f77 0%, #088395 100%);
  padding: 64px 0;
}
.nau-stats__inner {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 32px;
}
.nau-stats__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
}
.nau-stats__card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 8px 32px;
  position: relative;
}
.nau-stats__card:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0; top: 10%; bottom: 10%;
  width: 1px;
  background: rgba(255,255,255,0.18);
}
.nau-stats__number {
  font-family: 'Inter', Georgia, sans-serif;
  font-size: clamp(2.2rem, 5vw, 3.4rem);
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.04em;
  line-height: 1;
}
.nau-stats__unit {
  font-size: 0.85rem;
  font-weight: 600;
  color: rgba(255,255,255,0.62);
  text-transform: uppercase;
  letter-spacing: 0.10em;
  margin-top: 4px;
}
.nau-stats__label {
  font-size: 0.875rem;
  color: rgba(255,255,255,0.72);
  line-height: 1.45;
  margin-top: 8px;
  max-width: 160px;
}

/* ================================================================
   VALUES
   ================================================================ */
.nau-values {
  background: #f5fbfd;
  padding: 88px 0 96px;
}
.nau-values__inner {
  max-width: 1040px;
  margin: 0 auto;
  padding: 0 32px;
  text-align: center;
}
.nau-values__heading {
  font-family: 'Inter', Georgia, sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  font-weight: 700;
  color: #0A4D68;
  letter-spacing: -0.03em;
  margin: 0 0 56px;
}
.nau-values__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  text-align: left;
}
.nau-values__card {
  background: #ffffff;
  border: 1px solid rgba(8,131,149,0.12);
  border-radius: 20px;
  padding: 36px 32px;
  box-shadow: 0 4px 24px rgba(10,77,104,0.07);
  transition: transform 0.26s ease, box-shadow 0.26s ease;
}
.nau-values__card:hover {
  transform: translateY(-6px);
  box-shadow: 0 18px 52px rgba(10,77,104,0.13);
}
.nau-values__card-icon {
  width: 52px; height: 52px;
  border-radius: 14px;
  background: linear-gradient(135deg, #e8f7fb 0%, #d0f0f5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #088395;
  margin-bottom: 20px;
}
.nau-values__card-title {
  font-family: 'Inter', Georgia, sans-serif;
  font-size: 1.125rem;
  font-weight: 700;
  color: #0A4D68;
  letter-spacing: -0.015em;
  margin: 0 0 10px;
}
.nau-values__card-text {
  font-size: 0.9375rem;
  line-height: 1.72;
  color: #2d4a54;
  margin: 0;
}

/* ================================================================
   CTA
   ================================================================ */
.nau-cta {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #0A4D68 0%, #088395 60%, #05b8cc 100%);
  padding: 96px 0 104px;
  text-align: center;
}
.nau-cta__orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}
.nau-cta__orb--a {
  width: 520px; height: 520px;
  background: rgba(255,255,255,0.07);
  top: -160px; right: -90px;
}
.nau-cta__orb--b {
  width: 320px; height: 320px;
  background: rgba(5,184,204,0.14);
  bottom: -90px; left: -50px;
}
.nau-cta__inner {
  position: relative;
  z-index: 1;
  max-width: 720px;
  margin: 0 auto;
  padding: 0 24px;
}
.nau-cta__kicker {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.20em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.62);
  margin: 0 0 20px;
  display: block;
}
.nau-cta__heading {
  font-family: 'Inter', Georgia, sans-serif;
  font-size: clamp(1.9rem, 4vw, 2.9rem);
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.025em;
  line-height: 1.18;
  margin: 0 0 48px;
}
.nau-cta__actions {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}
.nau-cta__btn {
  display: inline-block;
  font-family: 'Inter', Georgia, sans-serif;
  font-size: 0.9375rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 17px 46px;
  border-radius: 50px;
  transition: background 0.25s ease, color 0.25s ease,
              transform 0.22s ease, box-shadow 0.25s ease;
}
.nau-cta__btn--primary {
  background: #ffffff;
  color: #0A4D68;
  box-shadow: 0 8px 32px rgba(0,0,0,0.20);
}
.nau-cta__btn--primary:hover {
  background: #e8f7fb;
  transform: translateY(-3px);
  box-shadow: 0 16px 48px rgba(0,0,0,0.28);
}
.nau-cta__btn--secondary {
  background: transparent;
  color: rgba(255,255,255,0.88);
  border: 1.5px solid rgba(255,255,255,0.38);
}
.nau-cta__btn--secondary:hover {
  background: rgba(255,255,255,0.11);
  border-color: rgba(255,255,255,0.68);
  transform: translateY(-3px);
}

/* ================================================================
   RESPONSIVE
   ================================================================ */
@media (max-width: 899px) {
  .nau-values__grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 749px) {
  .nau-hero         { padding: 88px 0 80px; }
  .nau-story        { padding: 56px 0 48px; }
  .nau-story__inner { padding: 0 20px; }
  .nau-story__rte   { font-size: 1rem; }
  .nau-story__rte > p:first-of-type { font-size: 1.05rem; }
  .nau-mission      { padding: 68px 0 76px; }
  .nau-mission__inner { padding: 0 20px; }
  .nau-mission__heading { font-size: 2rem; margin-bottom: 40px; }
  .nau-mission__step { gap: 18px; }
  .nau-stats        { padding: 52px 0; }
  .nau-stats__inner { padding: 0 20px; }
  .nau-stats__grid  { grid-template-columns: 1fr; }
  .nau-stats__card:not(:last-child)::after { display: none; }
  .nau-values       { padding: 68px 0 76px; }
  .nau-values__inner { padding: 0 20px; }
  .nau-values__grid { grid-template-columns: 1fr; }
  .nau-values__heading { margin-bottom: 36px; font-size: 1.9rem; }
  .nau-cta          { padding: 68px 0 76px; }
  .nau-cta__inner   { padding: 0 20px; }
  .nau-cta__heading { font-size: 1.75rem; margin-bottom: 36px; }
  .nau-cta__btn     { padding: 15px 32px; width: 100%; max-width: 280px; display: block; margin: 0 auto; }
  .nau-cta__actions { gap: 14px; }
  .nau-video-card   { flex-direction: column; border-radius: 18px; }
  .nau-video-card:hover { transform: none; }
  .nau-video-card__media { flex: none; }
  .nau-video-card__media iframe {
    position: static !important;
    width: 100% !important;
    height: auto !important;
    aspect-ratio: 16/9;
  }
  .nau-video-card__media-sizer { display: none; }
  .nau-video-card__body { padding: 28px 24px; }
}
@media (prefers-reduced-motion: reduce) {
  .nau-hero__orb, .nau-hero__scroll { animation: none !important; }
  .nau-values__card, .nau-cta__btn { transition: none !important; }
  .nau-values__card:hover, .nau-mission__step:hover .nau-mission__icon { transform: none !important; }
  .nau-video-card { transition: none !important; }
  .nau-video-card:hover { transform: none !important; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {

  /* Remove theme's default top padding so hero is flush with the navbar */
  var main = document.getElementById('MainContent');
  if (main) main.style.paddingTop = '0';

  /* ── 1. Convert each <table> row → .nau-video-card flex card ── */
  var storyRte = document.getElementById('nau-story-rte');
  if (storyRte) {
    var tables = storyRte.querySelectorAll('table');
    for (var t = tables.length - 1; t >= 0; t--) {
      var table = tables[t];
      var rows = table.querySelectorAll('tr');
      var fragment = document.createDocumentFragment();

      for (var r = 0; r < rows.length; r++) {
        var row = rows[r];
        var cells = row.querySelectorAll('td, th');
        if (cells.length < 2) continue;

        var card = document.createElement('div');
        card.className = 'nau-video-card';

        /* Left: media */
        var mediaDiv = document.createElement('div');
        mediaDiv.className = 'nau-video-card__media';
        var sizer = document.createElement('div');
        sizer.className = 'nau-video-card__media-sizer';
        mediaDiv.appendChild(sizer);

        var iframe = cells[0].querySelector('iframe');
        if (iframe) {
          iframe.removeAttribute('width');
          iframe.removeAttribute('height');
          iframe.style.cssText = '';
          mediaDiv.appendChild(iframe);
        } else {
          while (cells[0].firstChild) { mediaDiv.appendChild(cells[0].firstChild); }
        }

        /* Right: text */
        var bodyDiv = document.createElement('div');
        bodyDiv.className = 'nau-video-card__body';
        while (cells[1].firstChild) { bodyDiv.appendChild(cells[1].firstChild); }

        card.appendChild(mediaDiv);
        card.appendChild(bodyDiv);
        fragment.appendChild(card);
      }

      table.parentNode.replaceChild(fragment, table);
    }
  }

  /* ── 2. Move "What's Unique" content to after the Mission section ── */
  var rte = document.getElementById('nau-story-rte');
  if (!rte) return;
  var headings = rte.querySelectorAll('h1,h2,h3,h4,h5,h6');
  var target = null;
  for (var i = 0; i < headings.length; i++) {
    if (headings[i].textContent.toLowerCase().indexOf('unique') !== -1) {
      target = headings[i]; break;
    }
  }
  if (!target) return;
  var nodes = [];
  var n = target;
  while (n) { nodes.push(n); n = n.nextSibling; }
  var dest = document.getElementById('nau-unique-rte');
  if (!dest) return;
  for (var k = 0; k < nodes.length; k++) { dest.appendChild(nodes[k]); }
  var sec = document.getElementById('nau-unique-section');
  if (sec) sec.style.display = '';

});
</script>

{% else %}

<div class="page-width">
  <div class="grid">
    <div class="grid__item medium-up--five-sixths medium-up--push-one-twelfth">
      <div class="section-header text-center">
        <h1>{{ page.title }}</h1>
      </div>
      <div class="rte">
        {{ page.content }}
      </div>
    </div>
  </div>
</div>

{% endif %}

{% endif %}
