<div class="grid-view-item{% unless product.available %} product-price--sold-out grid-view-item--sold-out{% endunless %} ni-product-card">
  {%- assign total_inventory = 0 -%}
  {%- for variant in product.variants -%}
    {%- assign total_inventory = total_inventory | plus: variant.inventory_quantity -%}
  {%- endfor -%}
  <a class="grid-view-item__link grid-view-item__image-container" href="{{ product.url | within: collection }}">
    {% if product.compare_at_price > product.price and product.available and total_inventory >= 20 %}
      {%- assign savings = product.compare_at_price | minus: product.price -%}
      {%- assign percentage = savings | times: 100.0 | divided_by: product.compare_at_price | round -%}
      <span class="badge sale-badge">SAVE {{ percentage }}%</span>
    {% endif %}
    <div class="custom-product-image-wrapper">
      <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" class="custom-product-image">
      <div class="cooling-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m19 5-7 7-7-7"/><path d="M2 12h20"/><path d="m5 19 7-7 7 7"/></svg>
        2+ HOURS COOLING
      </div>
    </div>

    {%- assign product_description = 'A wearable cooling solution designed for daily comfort and relief.' -%}
    {%- case product.handle -%}
      {%- when 'copy-of-cooling-scarf-purple' -%}
        {%- assign product_description = 'A soft and versatile scarf design that keeps you cool while fitting naturally into your everyday style.' -%}
      {%- when 'cooling-necklace-bright-purple-with-an-extra-cooling-sphere' -%}
        {%- assign product_description = 'A bold, eye-catching design that keeps you cool while standing out.' -%}
      {%- when 'cooling-scarf-paisley-cooling-balls-included' -%}
        {%- assign product_description = 'A classic paisley design that adds character while delivering consistent cooling.' -%}
      {%- when 'cooling-scarf-grey' -%}
        {%- assign product_description = 'A clean and minimal style designed for everyday comfort and easy wear.' -%}
      {%- when 'cooling-necklace-coral-turquoise' -%}
        {%- assign product_description = 'A vibrant, statement design inspired by timeless style that keeps you cool throughout the day.' -%}
      {%- when 'cooling-necklace-grey' -%}
        {%- assign product_description = 'A minimal and modern design that fits seamlessly into any daily routine.' -%}
      {%- when 'nano-ice-cooling-necklace-black' -%}
        {%- assign product_description = 'A sleek and understated design built for long-lasting comfort in daily use.' -%}
      {%- when 'cooling-necklace-graphic-print' -%}
        {%- assign product_description = 'A bright and expressive design that adds energy while keeping you cool.' -%}
    {%- endcase -%}

    <div class="h4 grid-view-item__title">{{ product.title | replace: 'COOLING BALLS INCLUDED!', 'Cooling balls included!' }}</div>
    <div class="product-card-desc">{{ product_description }}</div>
    {% if section.settings.show_vendor %}
      <div class="grid-view-item__vendor">{{ product.vendor }}</div>
    {% endif %}
    <div class="grid-view-item__meta">
      {% include 'product-price' %}
    </div>
  </a>
</div>
