<div class="grid-view-item{% unless product.available %} product-price--sold-out grid-view-item--sold-out{% endunless %} ni-product-card">
  {%- assign total_inventory = 0 -%}
  {%- for variant in product.variants -%}
    {%- assign total_inventory = total_inventory | plus: variant.inventory_quantity -%}
  {%- endfor -%}
  <a class="grid-view-item__link grid-view-item__image-container" href="{{ product.url | within: collection }}">
    {% if product.available and total_inventory >= 10 %}
      {% if product.compare_at_price > product.price %}
        {%- assign savings = product.compare_at_price | minus: product.price -%}
        {%- assign percentage = savings | times: 100.0 | divided_by: product.compare_at_price | round -%}
        <span class="badge sale-badge">SAVE {{ percentage }}%</span>
      {% else %}
        <span class="badge sale-badge">SALE</span>
      {% endif %}
    {% endif %}
    <div class="custom-product-image-wrapper">
      <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" class="custom-product-image">
      <div class="cooling-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m19 5-7 7-7-7"/><path d="M2 12h20"/><path d="m5 19 7-7 7 7"/></svg>
        2+ HOURS COOLING
      </div>
    </div>

    {%- assign product_handle = product.handle | strip -%}
    {%- assign product_title = product.title | replace: 'COOLING BALLS INCLUDED!', 'Cooling balls included!' -%}
    {%- assign product_description = 'A wearable cooling solution designed for daily comfort and relief.' -%}
    {%- case product_handle -%}
      {%- when 'copy-of-cooling-scarf-purple' -%}
        {%- assign product_title = 'Cooling Scarf - Purple (Cooling spheres included)' -%}
        {%- assign product_description = 'A soft, statement scarf that adds a touch of color while keeping you cool for over 2 hours' -%}
      {%- when 'cooling-necklace-bright-purple-with-an-extra-cooling-sphere' -%}
        {%- assign product_title = 'Cooling Necklace - Purple' -%}
        {%- assign product_description = 'A bold statement piece designed to stand out while delivering long-lasting cooling around your neck.' -%}
      {%- when 'cooling-scarf-paisley-cooling-balls-included' -%}
        {%- assign product_title = 'Cooling Scarf - Paisley (Cooling spheres included)' -%}
        {%- assign product_description = 'A classic paisley statement design that brings character to your outfit while providing steady cooling comfort for hours.' -%}
      {%- when 'cooling-scarf-grey' -%}
        {%- assign product_title = 'Cooling Scarf - Grey (Cooling spheres included)' -%}
        {%- assign product_description = 'A clean, everyday statement scarf that pairs with anything while keeping you cool and comfortable for over 2 hours.' -%}
      {%- when 'cooling-necklace-multi-color-gatsby' -%}
        {%- assign product_title = 'Cooling Necklace - Multi Color (Great Gatsby)' -%}
        {%- assign product_description = 'A vibrant, statement necklace inspired by timeless style, designed to keep you cool for hours while elevating your look.' -%}
      {%- when 'cooling-necklace-grey' -%}
        {%- assign product_title = 'Cooling Necklace - Grey' -%}
        {%- assign product_description = 'A modern statement piece that blends effortlessly into your routine while delivering consistent cooling for 2+ hours.' -%}
      {%- when 'nano-ice-cooling-necklace-black' -%}
        {%- assign product_title = 'Cooling Necklace - Black' -%}
        {%- assign product_description = 'A bold, statement design that keeps you cool and comfortable for extended wear throughout the day.' -%}
      {%- when 'cooling-necklace-multi-color-1' -%}
        {%- assign product_title = 'Cooling Necklace – Vibrant Leaf' -%}
        {%- assign product_description = 'A bright, expressive statement piece that adds energy to your outfit while providing long-lasting cooling comfort.' -%}
    {%- endcase -%}

    <div class="h4 grid-view-item__title">{{ product_title }}</div>
    <div class="product-card-desc">{{ product_description }}</div>
    {% if section.settings.show_vendor %}
      <div class="grid-view-item__vendor">{{ product.vendor }}</div>
    {% endif %}
    <div class="grid-view-item__meta">
      {% include 'product-price' %}
    </div>
  </a>
</div>
