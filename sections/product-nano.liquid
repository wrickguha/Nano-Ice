{{ 'product-nano.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-nano.js' | asset_url }}" defer></script>

<div class="nano-main-wrapper" id="NanoProductSection" data-product-handle="{{ product.handle }}" data-section-id="{{ section.id }}">
  {%- assign current_variant = product.selected_or_first_available_variant -%}

  <!-- 1. HERO SECTION -->
  <section class="nano-hero">
    <div class="nano-container nano-hero__grid">

      <!-- LEFT COLUMN: Image Gallery -->
      <div class="nano-hero__gallery">
        <div class="nano-gallery__main-wrapper">
          <div class="nano-cooling-badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m19 5-7 7-7-7"/><path d="M2 12h20"/><path d="m5 19 7-7 7 7"/></svg>
            <span>2+<br>HOURS<br><small>COOLING</small></span>
          </div>
          
          <button class="nano-gallery__arrow nano-gallery__arrow--prev" aria-label="Previous image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          
          <div class="nano-gallery__featured">
            {% for image in product.images %}
              <div id="NanoImageWrapper-{{ section.id }}-{{ image.id }}"
                   class="product-single__photo-wrapper js {% unless forloop.first %}hide{% endunless %}"
                   data-image-id="{{ image.id }}">
                <img
                  class="nano-main-image {% if forloop.first %}is-active{% endif %}"
                  src="{{ image | img_url: '1000x' }}"
                  alt="{{ image.alt | default: product.title }}"
                  data-image-id="{{ image.id }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                >
              </div>
            {% endfor %}
          </div>
          
          <button class="nano-gallery__arrow nano-gallery__arrow--next" aria-label="Next image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
        <!-- Removed duplicate feature points under product image as requested -->

        <!-- Thumbnail Strip -->
        {% if product.images.size > 1 %}
        <div class="nano-gallery__thumbnails">
          {% for image in product.images limit:4 %}
            <div class="nano-gallery__thumb {% if forloop.first %}is-active{% endif %}"
                 data-image-id="{{ image.id }}">
              <img src="{{ image | img_url: '150x' }}" alt="{{ image.alt | default: product.title }}">
            </div>
          {% endfor %}
        </div>
        {% endif %}
      </div><!-- /nano-hero__gallery -->

      <!-- RIGHT COLUMN: Product Info -->
      <div class="nano-hero__info">
        <h1 class="nano-title" itemprop="name">{{ product.title }}</h1>
        
        <div class="nano-price" itemprop="offers" itemscope itemtype="http://schema.org/Offer">
          <meta itemprop="priceCurrency" content="{{ shop.currency }}">
          <link itemprop="availability" href="http://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}">
          <span id="NanoPrice" class="nano-price__current" itemprop="price" content="{{ current_variant.price | divided_by: 100.00 }}">{{ current_variant.price | money }}</span>
        </div>

        <a href="#reviews" class="nano-review-link">See reviews
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </a>

        <div class="nano-callout">
          <span class="nano-callout-icon">✨</span>
          <p>A bold, eye-catching design that keeps you cool while standing out.</p>
        </div>

        <div class="nano-short-desc">
          Stay cool for over 2 hours with a wearable cooling necklace designed for real daily use. No water, no mess. Just consistent relief when you need it.
        </div>

        {%- form 'product', product, id: 'NanoAddToCartForm', class: 'nano-form', enctype: 'multipart/form-data' -%}
          <input type="hidden" name="id" id="NanoVariantId" value="{{ current_variant.id }}">

          <div class="nano-form__actions">
            {% if section.settings.show_quantity_selector %}
            <div class="nano-qty">
              <button type="button" class="nano-qty__btn" data-action="minus">-</button>
              <input type="number" id="NanoQuantity" name="quantity" value="1" min="1" class="nano-qty__input" pattern="[0-9]*">
              <button type="button" class="nano-qty__btn" data-action="plus">+</button>
            </div>
            {% endif %}

            <button type="submit" name="add" id="NanoAddToCartBtn" class="nano-cta-button" {% unless current_variant.available %}disabled{% endunless %}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              <span class="nano-cta__text">
                {% unless current_variant.available %}Sold Out{% else %}ADD TO CART{% endunless %}
              </span>
            </button>
          </div>
        {%- endform -%}

        <div class="nano-trust-icons">
          <div class="nano-trust-item">
            <!-- Cooling Icon -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2a4a7b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20M4.93 4.93l14.14 14.14M19.07 4.93L4.93 19.07"/></svg>
            <span>2+ hours of<br>cooling relief</span>
          </div>
          <div class="nano-trust-item">
            <!-- Star/Statement Icon -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2a4a7b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15 8.5 22 9.3 17 14.1 18.2 21 12 17.8 5.8 21 7 14.1 2 9.3 9 8.5 12 2"/></svg>
            <span>Designed to<br>make a statement</span>
          </div>
          <div class="nano-trust-item">
            <!-- Reusable Icon -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2a4a7b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"/><path d="M3 13a9 9 0 0 1 14.19-7.36L21 8"/><path d="M3 22v-6h6"/><path d="M21 11a9 9 0 0 1-14.19 7.36L3 16"/></svg>
            <span>Reusable —<br>just freeze & wear</span>
          </div>
          <div class="nano-trust-item">
            <!-- Location/Boston Icon -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2a4a7b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-6-5.686-6-10A6 6 0 0 1 18 11c0 4.314-6 10-6 10z"/><circle cx="12" cy="11" r="2.5"/></svg>
            <span>Manufactured<br>near Boston</span>
          </div>
          <div class="nano-trust-item">
            <!-- Free Returns Icon -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2a4a7b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span>Free returns</span>
          </div>
        </div>
      </div><!-- /nano-hero__info -->
    </div><!-- /nano-container -->
  </section><!-- /nano-hero -->

  <!-- ACCORDION SECTION -->
  <section class="nano-accordion-section nano-container">
    <div class="nano-accordion">
      <div class="nano-accordion__item">
        <button class="nano-accordion__toggle">
          <div class="nano-accordion__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="m19 5-7 7-7-7"/><path d="M2 12h20"/><path d="m5 19 7-7 7 7"/></svg>
            How It Works
          </div>
          <svg class="nano-accordion__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="nano-accordion__content">
          <div class="nano-accordion__inner">
            <p>Nano-Ice uses a proprietary cooling technology inside the spheres. Simply place the necklace in the freezer for 2 hours, and it will stay cool for over 2 hours at room temperature, providing consistent relief.</p>
          </div>
        </div>
      </div>

      <div class="nano-accordion__item">
        <button class="nano-accordion__toggle">
          <div class="nano-accordion__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
            Key Benefits
          </div>
          <svg class="nano-accordion__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="nano-accordion__content">
          <div class="nano-accordion__inner">
            <ul>
              <li>Instant relief from hot flashes and heat fatigue.</li>
              <li>No dripping water, completely dry exterior.</li>
              <li>Reusable thousands of times.</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="nano-accordion__item">
        <button class="nano-accordion__toggle">
          <div class="nano-accordion__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="19" r="3"/><path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"/><circle cx="18" cy="5" r="3"/></svg>
            Design & Comfort
          </div>
          <svg class="nano-accordion__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="nano-accordion__content">
          <div class="nano-accordion__inner">
            <p>Designed to drape comfortably around your neck, the cooling spheres are encased in a soft, premium fabric that feels great against the skin while looking stylish.</p>
          </div>
        </div>
      </div>

      <div class="nano-accordion__item">
        <button class="nano-accordion__toggle">
          <div class="nano-accordion__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            Important Note
          </div>
          <svg class="nano-accordion__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="nano-accordion__content">
          <div class="nano-accordion__inner">
            <p>Do not bend the spheres when frozen solid. Allow them to slightly soften if you need to adjust the shape.</p>
          </div>
        </div>
      </div>

      <div class="nano-accordion__item">
        <button class="nano-accordion__toggle">
          <div class="nano-accordion__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 18H3c-.6 0-1-.4-1-1V7c0-.6.4-1 1-1h10c.6 0 1 .4 1 1v11"/><path d="M14 9h4l4 4v4c0 .6-.4 1-1 1h-2"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
            Shipping
          </div>
          <svg class="nano-accordion__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="nano-accordion__content">
          <div class="nano-accordion__inner">
            <p>Free standard shipping on all orders over $50 within the contiguous USA. International shipping available.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS SECTION -->
