  {%- assign _has_video_review = false -%}
  {%- if product.handle == 'cooling-necklace-grey' or product.handle == 'cooling-necklace-bright-purple-with-an-extra-cooling-sphere' or product.handle == 'copy-of-cooling-scarf-purple' or product.handle == 'cooling-scarf-paisley-cooling-balls-included' or product.handle == 'cooling-scarf-grey' -%}
