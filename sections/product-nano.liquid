
{{ 'product-nano.css' | asset_url | stylesheet_tag }}
<!-- GSAP & ScrollTrigger for premium animations -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" defer></script>
<script src="{{ 'product-nano.js' | asset_url }}" defer></script>

<div class="nano-main-wrapper" id="NanoProductSection" data-product-handle="{{ product.handle }}" data-section-id="{{ section.id }}">
  {%- assign current_variant = product.selected_or_first_available_variant -%}

  <!-- 1. HERO SECTION -->
  <section class="nano-hero">
    <div class="nano-container nano-hero__grid">

      <!-- LEFT COLUMN: Image Gallery + 3D Viewer -->
      <div class="nano-hero__gallery">

        <!-- Featured Image -->
        <div class="nano-gallery__featured">
          {% for image in product.images %}
            <div id="NanoImageWrapper-{{ section.id }}-{{ image.id }}"
                 class="product-single__photo-wrapper js {% unless forloop.first %}hide{% endunless %}"
                 data-image-id="{{ image.id }}">
              <img
                class="nano-main-image {% if forloop.first %}is-active{% endif %}"
                src="{{ image | img_url: '1000x' }}"
                alt="{{ image.alt | default: product.title }}"
                data-image-id="{{ image.id }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              >
            </div>
          {% endfor %}
        </div>



        <!-- Thumbnail Strip -->
        {% if product.images.size > 1 %}
        <div class="nano-gallery__thumbnails">
          {% for image in product.images %}
            <div class="nano-gallery__thumb {% if forloop.first %}is-active{% endif %}"
                 data-image-id="{{ image.id }}">
              <img src="{{ image | img_url: '150x' }}" alt="{{ image.alt | default: product.title }}">
            </div>
          {% endfor %}
        </div>
        {% endif %}



      {% if product.handle == 'nano-ice-cooling-necklace-black' %}
      <div class="nano-video-review-card" style="max-width:700px;margin:2rem auto 0 auto;padding:2.5rem 1.5rem;background:#eaf4fb;border-radius:24px;box-shadow:0 4px 24px rgba(47,101,156,0.10);display:flex;align-items:center;gap:2rem;flex-wrap:wrap;">
        <div style="flex:0 0 160px;display:flex;justify-content:center;align-items:center;">
          <div style="width:140px;height:140px;border-radius:50%;overflow:hidden;box-shadow:0 2px 12px rgba(47,101,156,0.13);background:#fff;display:flex;align-items:center;justify-content:center;">
            <video style="width:140px;height:140px;object-fit:cover;" controls autoplay loop playsinline>
              <source src="https://cdn.shopify.com/videos/c/o/v/8592fdaf6cb3498d83426eecf40b179a.mp4" type="video/mp4">
              Your browser does not support the video tag.
            </video>
          </div>
        </div>
        <div style="flex:1;min-width:220px;">
          <div style="color:#222;font-size:1.5rem;font-weight:700;margin-bottom:0.5rem;">Loved By Customers</div>
          <div style="color:#f5b50a;font-size:1.3rem;margin-bottom:0.5rem;">★★★★★</div>
          <div style="font-size:1.08rem;color:#333;margin-bottom:0.5rem;">This video review shows the Black Cooling Necklace in action! Real people, real results.</div>
          <div style="color:#3a3a3a;font-size:1rem;font-style:italic;">- Verified Customer</div>
        </div>
      </div>
      {% endif %}
      </div><!-- /nano-hero__gallery -->

      <!-- RIGHT COLUMN: Product Info -->
      <div class="nano-hero__info">
        <div class="nano-hero__header">
          <h1 class="nano-title" itemprop="name">{{ product.title }}</h1>
          <div class="nano-price" itemprop="offers" itemscope itemtype="http://schema.org/Offer">
            <meta itemprop="priceCurrency" content="{{ shop.currency }}">
            <link itemprop="availability" href="http://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}">
            <span id="NanoPrice" class="nano-price__current" itemprop="price" content="{{ current_variant.price | divided_by: 100.00 }}">{{ current_variant.price | money }}</span>
            {% if current_variant.compare_at_price > current_variant.price %}
              <span id="NanoComparePrice" class="nano-price__compare"><s>{{ current_variant.compare_at_price | money }}</s></span>
            {% endif %}
          </div>
        </div>

        {% if section.settings.show_vendor %}
          <p itemprop="brand" class="nano-vendor">{{ product.vendor }}</p>
        {% endif %}

        <!-- Trust badges removed as requested -->

        {%- form 'product', product, id: 'NanoAddToCartForm', class: 'nano-form', enctype: 'multipart/form-data' -%}

          <!-- Variant JSON for JS -->
          <script type="application/json" id="NanoVariantJSON">
            {{ product.variants | json }}
          </script>
          <input type="hidden" name="id" id="NanoVariantId" value="{{ current_variant.id }}">

          <!-- Variant Option Pills -->
          {% unless product.has_only_default_variant %}
          <div class="nano-variants">
            {% for option in product.options_with_values %}
              <div class="nano-option-wrapper">
                <label class="nano-option-label">{{ option.name }}</label>
                <div class="nano-pill-group" data-option-index="{{ forloop.index0 }}">
                  {% for value in option.values %}
                    <button
                      type="button"
                      class="nano-pill {% if option.selected_value == value %}is-active{% endif %}"
                      data-value="{{ value | escape }}"
                      data-option-index="{{ forloop.parentloop.index0 }}"
                    >{{ value }}</button>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
          {% endunless %}

          <!-- Quantity + Add to Cart -->
          <div class="nano-form__actions">
            {% if section.settings.show_quantity_selector %}
            <div class="nano-qty">
              <button type="button" class="nano-qty__btn" data-action="minus">-</button>
              <input type="number" id="NanoQuantity" name="quantity" value="1" min="1" class="nano-qty__input" pattern="[0-9]*">
              <button type="button" class="nano-qty__btn" data-action="plus">+</button>
            </div>
            {% endif %}

            <button type="submit" name="add" id="NanoAddToCartBtn" class="nano-cta-button" {% unless current_variant.available %}disabled{% endunless %}>
              <span class="nano-cta__text">
                {% unless current_variant.available %}{{ 'products.product.sold_out' | t }}{% else %}{{ 'products.product.add_to_cart' | t }}{% endunless %}
              </span>
              <span class="nano-cta__shine"></span>
            </button>
          </div>
        {%- endform -%}

        <!-- Product Description -->
        <div class="nano-desc-wrapper">
          <div class="nano-desc-content rte" itemprop="description">
            {{ product.description }}
          </div>
        </div>

        <!-- Social Share Buttons -->
        <div class="nano-social-share">
          <span class="nano-social-share__label">Share this product:</span>
          <div class="nano-social-share__buttons">
            {%- assign share_url = shop.url | append: product.url -%}
            {%- assign share_text = product.title | url_encode -%}
            <a class="nano-social-btn nano-social-btn--facebook"
               href="https://www.facebook.com/sharer/sharer.php?u={{ share_url | url_encode }}"
               target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              <span>Facebook</span>
            </a>
            <a class="nano-social-btn nano-social-btn--twitter"
               href="https://twitter.com/intent/tweet?url={{ share_url | url_encode }}&text={{ share_text }}"
               target="_blank" rel="noopener noreferrer" aria-label="Share on Twitter">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 4l16 16M4 20 20 4" stroke="currentColor" stroke-width="0" fill="none"/><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L2.25 2.25h6.928l4.279 5.656 4.787-5.656Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              <span>Twitter</span>
            </a>
            <button class="nano-social-btn nano-social-btn--instagram"
               data-share-url="{{ share_url }}" aria-label="Copy link to share on Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              <span>Instagram</span>
            </button>
          </div>
          <div class="nano-social-share__toast" id="NanoShareToast">Link copied! Paste it on Instagram.</div>
        </div>

      </div><!-- /nano-hero__info -->

      <!-- TESTIMONIALS — per-product via metafields (truly unique per product) -->
      {%- assign t1_text   = product.metafields.testimonials.t1_text.value -%}
      {%- assign t1_author = product.metafields.testimonials.t1_author.value -%}
      {%- assign t1_stars  = product.metafields.testimonials.t1_stars.value -%}
      {%- assign t1_photo  = product.metafields.testimonials.t1_photo.value -%}
      {%- assign t2_text   = product.metafields.testimonials.t2_text.value -%}
      {%- assign t2_author = product.metafields.testimonials.t2_author.value -%}
      {%- assign t2_stars  = product.metafields.testimonials.t2_stars.value -%}
      {%- assign t2_photo  = product.metafields.testimonials.t2_photo.value -%}
      {%- assign t3_text   = product.metafields.testimonials.t3_text.value -%}
      {%- assign t3_author = product.metafields.testimonials.t3_author.value -%}
      {%- assign t3_stars  = product.metafields.testimonials.t3_stars.value -%}
      {%- assign t3_photo  = product.metafields.testimonials.t3_photo.value -%}
      {%- assign t4_text   = product.metafields.testimonials.t4_text.value -%}
      {%- assign t4_author = product.metafields.testimonials.t4_author.value -%}
      {%- assign t4_stars  = product.metafields.testimonials.t4_stars.value -%}
      {%- assign t4_photo  = product.metafields.testimonials.t4_photo.value -%}
      {%- assign has_metafield_testimonials = false -%}
      {%- if t1_text != blank or t2_text != blank or t3_text != blank or t4_text != blank -%}
        {%- assign has_metafield_testimonials = true -%}
      {%- endif -%}

      {%- assign matching_nano_blocks = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'nano_testimonial' or block.type == 'nano_video_review' -%}
          {%- if block.settings.product_handle == blank or block.settings.product_handle == product.handle -%}
            {%- assign matching_nano_blocks = matching_nano_blocks | plus: 1 -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      {% if section.settings.enable_testimonials %}
        {% if has_metafield_testimonials %}
          <div class="nano-testimonials-inline">
            <h3 class="nano-testimonials-inline__title">{{ section.settings.testimonials_title }}</h3>
            <p class="nano-testimonials-inline__subtitle">{{ section.settings.testimonials_subtitle }}</p>
            <div class="nano-portraits__grid">
              {% if t1_text != blank %}
                <div class="nano-portrait-card">
                  {% if t1_photo != blank %}
                    <img src="{{ t1_photo }}" alt="{{ t1_author }}" class="nano-portrait__img">
                  {% else %}
                    <img src="https://i.pravatar.cc/400?u={{ t1_author | url_encode }}" alt="{{ t1_author }}" class="nano-portrait__img">
                  {% endif %}
                  <div class="nano-portrait__overlay">
                    <div class="nano-stars">{{ t1_stars | default: '★★★★★' }}</div>
                    <p>{{ t1_text }}</p>
                    <span class="nano-portrait__name">- {{ t1_author }}</span>
                  </div>
                </div>
              {% endif %}
              {% if t2_text != blank %}
                <div class="nano-portrait-card">
                  {% if t2_photo != blank %}
                    <img src="{{ t2_photo }}" alt="{{ t2_author }}" class="nano-portrait__img">
                  {% else %}
                    <img src="https://i.pravatar.cc/400?u={{ t2_author | url_encode }}" alt="{{ t2_author }}" class="nano-portrait__img">
                  {% endif %}
                  <div class="nano-portrait__overlay">
                    <div class="nano-stars">{{ t2_stars | default: '★★★★★' }}</div>
                    <p>{{ t2_text }}</p>
                    <span class="nano-portrait__name">- {{ t2_author }}</span>
                  </div>
                </div>
              {% endif %}
              {% if t3_text != blank %}
                <div class="nano-portrait-card">
                  {% if t3_photo != blank %}
                    <img src="{{ t3_photo }}" alt="{{ t3_author }}" class="nano-portrait__img">
                  {% else %}
                    <img src="https://i.pravatar.cc/400?u={{ t3_author | url_encode }}" alt="{{ t3_author }}" class="nano-portrait__img">
                  {% endif %}
                  <div class="nano-portrait__overlay">
                    <div class="nano-stars">{{ t3_stars | default: '★★★★★' }}</div>
                    <p>{{ t3_text }}</p>
                    <span class="nano-portrait__name">- {{ t3_author }}</span>
                  </div>
                </div>
              {% endif %}
              {% if t4_text != blank %}
                <div class="nano-portrait-card">
                  {% if t4_photo != blank %}
                    <img src="{{ t4_photo }}" alt="{{ t4_author }}" class="nano-portrait__img">
                  {% else %}
                    <img src="https://i.pravatar.cc/400?u={{ t4_author | url_encode }}" alt="{{ t4_author }}" class="nano-portrait__img">
                  {% endif %}
                  <div class="nano-portrait__overlay">
                    <div class="nano-stars">{{ t4_stars | default: '★★★★★' }}</div>
                    <p>{{ t4_text }}</p>
                    <span class="nano-portrait__name">- {{ t4_author }}</span>
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        {% elsif matching_nano_blocks > 0 %}
          <div class="nano-testimonials-inline">
            <h3 class="nano-testimonials-inline__title">{{ section.settings.testimonials_title }}</h3>
            <p class="nano-testimonials-inline__subtitle">{{ section.settings.testimonials_subtitle }}</p>
            <div class="nano-portraits__grid">
              {% for block in section.blocks %}
                {% if block.type == 'nano_testimonial' %}
                  {% if block.settings.product_handle == blank or block.settings.product_handle == product.handle %}
                  <div class="nano-portrait-card" {{ block.shopify_attributes }}>
                    {% if block.settings.image_url != blank %}
                      <img src="{{ block.settings.image_url }}" alt="{{ block.settings.author }}" class="nano-portrait__img">
                    {% elsif block.settings.image != blank %}
                      <img src="{{ block.settings.image | img_url: '400x400', crop: 'center' }}" alt="{{ block.settings.author }}" class="nano-portrait__img">
                    {% else %}
                      <img src="https://i.pravatar.cc/400?u={{ block.settings.author | url_encode }}" alt="{{ block.settings.author }}" class="nano-portrait__img">
                    {% endif %}
                    <div class="nano-portrait__overlay">
                      <div class="nano-stars">{{ block.settings.rating }}</div>
                      <p>{{ block.settings.text }}</p>
                      <span class="nano-portrait__name">- {{ block.settings.author }}</span>
                    </div>
                  </div>
                  {% endif %}
                {% endif %}
                {% if block.type == 'nano_video_review' %}
                  {% if block.settings.product_handle == blank or block.settings.product_handle == product.handle %}
                  <div class="nano-portrait-card nano-video-card" {{ block.shopify_attributes }}>
                    <video class="nano-video-card__video" autoplay muted loop playsinline controls>
                      <source src="{{ block.settings.video_url }}" type="video/mp4">
                    </video>
                  </div>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      {% endif %}

    </div><!-- /nano-hero__grid -->
  </section><!-- /nano-hero -->


  {% if collection %}
  <div class="nano-return-link">
    <a href="{{ collection.url }}" class="nano-back-link">&#8592; Back to {{ collection.title }}</a>
  </div>
  {% endif %}





</div><!-- /nano-main-wrapper -->

{% schema %}
{
  "name": "Nano Ice Product",
  "tag": "section",
  "class": "nano-product-section",
  "settings": [
    {
      "type": "header",
      "content": "Trust Badges"
    },
    {
      "type": "checkbox",
      "id": "show_free_shipping",
      "label": "Show free shipping badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_returns",
      "label": "Show 30-day returns badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_premium_badge",
      "label": "Show premium cooling badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quantity_selector",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_share_buttons",
      "label": "Show social sharing buttons",
      "default": false
    },
    {
      "type": "header",
      "content": "Testimonials"
    },
    {
      "type": "checkbox",
      "id": "enable_testimonials",
      "label": "Enable testimonials section",
      "default": true
    },
    {
      "type": "text",
      "id": "testimonials_title",
      "label": "Testimonials section title",
      "default": "Loved By Thousands"
    },
    {
      "type": "text",
      "id": "testimonials_subtitle",
      "label": "Testimonials section subtitle",
      "default": "Real people, real results. See why customers can\u2019t stop talking about it."
    }
  ],
  "blocks": [
    {
      "type": "nano_testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer photo (uploaded)"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Customer photo URL (external)",
          "info": "If set, this overrides the uploaded photo above."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Customer name",
          "default": "Happy Customer"
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Star rating",
          "default": "\u2605\u2605\u2605\u2605\u2605"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Testimonial text",
          "default": "Great product!"
        },
        {
          "type": "text",
          "id": "product_handle",
          "label": "Product handle (leave blank to show on all products)",
          "info": "Only show this review on one specific product page, e.g. cooling-necklace-grey"
        }
      ]
    },
    {
      "type": "nano_video_review",
      "name": "Video Review",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL",
          "info": "Direct link to an .mp4 video file (e.g. CDN URL)"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Customer name",
          "default": "Happy Customer"
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Star rating",
          "default": "\u2605\u2605\u2605\u2605\u2605"
        },
        {
          "type": "text",
          "id": "product_handle",
          "label": "Product handle (leave blank to show on all products)",
          "info": "Only show this review on one specific product page, e.g. nano-ice-cooling-necklace-black"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nano Ice Product",
      "blocks": [
        {
          "type": "nano_testimonial",
          "settings": {
            "image_url": "https://i.pravatar.cc/400?img=47",
            "author": "Sarah M.",
            "rating": "\u2605\u2605\u2605\u2605\u2605",
            "text": "An absolute lifesaver during my hot flashes. Nothing else has worked this well and lasted this long."
          }
        },
        {
          "type": "nano_testimonial",
          "settings": {
            "image_url": "https://i.pravatar.cc/400?img=12",
            "author": "Jason T.",
            "rating": "\u2605\u2605\u2605\u2605\u2605",
            "text": "I work in a 110\u00b0F greenhouse and this is the only way I survive the shifts."
          }
        },
        {
          "type": "nano_testimonial",
          "settings": {
            "image_url": "https://i.pravatar.cc/400?img=32",
            "author": "Emily K.",
            "rating": "\u2605\u2605\u2605\u2605\u2605",
            "text": "Comfortable, fits perfectly, and actually stays cold for hours. Worth every penny."
          }
        },
        {
          "type": "nano_testimonial",
          "settings": {
            "image_url": "https://i.pravatar.cc/400?img=7",
            "author": "David R.",
            "rating": "\u2605\u2605\u2605\u2605\u2605",
            "text": "Bought one for my whole crew. Game changer for outdoor summer work. Will buy again."
          }
        }
      ]
    }
  ]
}
{% endschema %}
