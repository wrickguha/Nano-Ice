<div class="press-logos-section">
  <div class="page-width">
    <p class="press-logos__heading">As Featured In</p>
  </div>
  <div class="press-logos__track-wrapper">
    <div class="press-logos__track">
      <div class="press-logos__item"><img src="{{ 'press-cbs-boston.svg' | asset_url }}" alt="CBS Boston" loading="lazy"></div>
      <div class="press-logos__item"><img src="{{ 'press-boston-globe.avif' | asset_url }}" alt="Boston Globe" loading="lazy"></div>
      <div class="press-logos__item"><img src="{{ 'press-wicked-local.avif' | asset_url }}" alt="Wicked Local" loading="lazy"></div>
      <div class="press-logos__item"><img src="{{ 'press-fox13.jpg' | asset_url }}" alt="FOX 13" loading="lazy"></div>
      <div class="press-logos__item"><img src="{{ 'press-abc-boston.jpg' | asset_url }}" alt="ABC Boston" loading="lazy"></div>
      <div class="press-logos__item"><img src="{{ 'press-msnbc.jpg' | asset_url }}" alt="MSNBC" loading="lazy"></div>
      <!-- Duplicate set for seamless infinite scroll -->
      <div class="press-logos__item"><img src="{{ 'press-cbs-boston.svg' | asset_url }}" alt="CBS Boston" loading="lazy"></div>
      <div class="press-logos__item"><img src="{{ 'press-boston-globe.avif' | asset_url }}" alt="Boston Globe" loading="lazy"></div>
      <div class="press-logos__item"><img src="{{ 'press-wicked-local.avif' | asset_url }}" alt="Wicked Local" loading="lazy"></div>
      <div class="press-logos__item"><img src="{{ 'press-fox13.jpg' | asset_url }}" alt="FOX 13" loading="lazy"></div>
      <div class="press-logos__item"><img src="{{ 'press-abc-boston.jpg' | asset_url }}" alt="ABC Boston" loading="lazy"></div>
      <div class="press-logos__item"><img src="{{ 'press-msnbc.jpg' | asset_url }}" alt="MSNBC" loading="lazy"></div>
    </div>
  </div>
</div>

