  /* Product Card Customizations */
  .ni-product-card {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 15px;
    position: relative;
    background: #fff;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .ni-product-card:hover {
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
