    font-family: 'Playfair Display', serif;
    font-size: 56px;
    font-weight: 800;
    color: #1e3a8a;
    margin-bottom: 15px;
    line-height: 1.15;
    letter-spacing: -0.5px;
  }
  .custom-subtitle {
    font-size: 20px;
    color: #4b5563;
    margin-bottom: 25px;
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
  .custom-benefits-line {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    color: #374151;
    font-weight: 500;
  }
  .custom-benefits-line .heart-icon {
    color: #3b82f6; /* Nicer light blue */
  }

  .collection-toolbar {
    border-bottom: 1px solid #e5e7eb;
    padding-bottom: 15px;
    margin-bottom: 30px;
