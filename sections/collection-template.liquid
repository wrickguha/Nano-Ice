    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  .how-it-works-header h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 700;
    color: #1e3a8a;
  }
  .how-it-works-header .snow-icon {
    color: #1e3a8a;
  }
  .custom-how-it-works p {
    font-size: 14px;
    color: #374151;
    line-height: 1.5;
    margin-bottom: 15px;
  }
  .learn-more-link {
    display: inline-flex;
