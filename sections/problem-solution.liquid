<!-- ============================================================
     NANO-ICE — New Problem & Solution Section
     ============================================================ -->

<section class="ni-ps-new" id="ProblemSolution-{{ section.id }}">
  <div class="page-width">
    
    <!-- PROBLEM ROW -->
    <div class="ni-ps-row ni-ps-row--problem ni-ps-reveal">
      <div class="ni-ps-col ni-ps-col--image">
        <div class="ni-ps-image-wrapper">
          {% if section.settings.problem_image != blank %}
            <img src="{{ section.settings.problem_image | img_url: '800x' }}" alt="{{ section.settings.problem_title_1 | escape }}" loading="lazy">
          {% else %}
            <img src="{{ 'problem-heat-woman.jpg' | asset_url }}" alt="Problem" loading="lazy">
          {% endif %}
        </div>
      </div>
      <div class="ni-ps-col ni-ps-col--text">
        <div class="ni-ps-text-content">
          <h2 class="ni-ps-title-large">{{ section.settings.problem_title_1 }}</h2>
          <h3 class="ni-ps-subtitle-highlight">{{ section.settings.problem_title_2 }}</h3>
          <p class="ni-ps-footer-text">{{ section.settings.problem_footer }}</p>
          <div class="ni-ps-accent-line"></div>
        </div>
      </div>
    </div>

    <!-- SOLUTION ROW -->
    <div class="ni-ps-row ni-ps-row--solution ni-ps-reveal">
      <div class="ni-ps-col ni-ps-col--text">
        <div class="ni-ps-text-content">
          <h2 class="ni-ps-solution-title">
            {{ section.settings.solution_title | replace: 'Nano-ice', '<span class="ni-highlight">Nano-ice</span>' }}
          </h2>
          <div class="ni-ps-description">
            {{ section.settings.solution_description }}
          </div>
          {% if section.settings.solution_link_text != blank %}
            <a href="/pages/about-us" class="ni-ps-link">
              {{ section.settings.solution_link_text }} <span class="ni-arrow">→</span>
            </a>
          {% endif %}
        </div>
      </div>
      <div class="ni-ps-col ni-ps-col--image">
        <div class="ni-ps-image-wrapper">
          {% if section.settings.solution_image != blank %}
            <img src="{{ section.settings.solution_image | img_url: '800x' }}" alt="Nano-ice Solution" loading="lazy">
          {% else %}
            <img src="{{ 'solution-nano-ice-woman.jpg' | asset_url }}" alt="Solution" loading="lazy">
          {% endif %}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  :root {
    --ni-brand-blue: #05BFDB;
    --ni-dark-blue: #002B5B;
    --ni-text-grey: #64748b;
    --ni-bg-light: #f8fbff;
  }

  .ni-ps-new {
    padding: 80px 0;
    background: linear-gradient(180deg, #ffffff 0%, var(--ni-bg-light) 100%);
    overflow: hidden;
  }

  .ni-ps-row {
    display: flex;
    align-items: center;
    gap: 60px;
    margin-bottom: 80px;
  }

  .ni-ps-row:last-child {
    margin-bottom: 0;
  }

  .ni-ps-col {
    flex: 1;
  }

  /* Image Styling */
  .ni-ps-image-wrapper {
    width: 100%;
    border-radius: 30px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  }

  .ni-ps-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s ease;
  }

  .ni-ps-image-wrapper:hover img {
    transform: scale(1.03);
  }

  /* Text Styling - Problem */
  .ni-ps-text-content {
    max-width: 600px;
  }

  .ni-ps-title-large {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 700;
    color: var(--ni-dark-blue);
    line-height: 1.1;
    margin-bottom: 15px;
  }

  .ni-ps-subtitle-highlight {
    font-size: 36px;
    font-weight: 600;
    color: var(--ni-brand-blue);
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .ni-ps-footer-text {
    font-size: 24px;
    color: #94a3b8;
    margin-bottom: 25px;
  }

  .ni-ps-accent-line {
    width: 60px;
    height: 3px;
    background-color: var(--ni-brand-blue);
    border-radius: 2px;
  }

  /* Text Styling - Solution */
  .ni-ps-solution-title {
    font-size: 32px;
    font-weight: 600;
    color: #334155;
    margin-bottom: 30px;
  }

  .ni-ps-solution-title .ni-highlight {
    color: var(--ni-brand-blue);
    font-weight: 700;
    white-space: nowrap;
  }

  .ni-ps-description {
    font-size: 18px;
    line-height: 1.6;
    color: #475569;
    margin-bottom: 35px;
  }

  .ni-ps-description strong {
    color: var(--ni-brand-blue);
    font-weight: 600;
  }

  .ni-ps-link {
    display: inline-flex;
    align-items: center;
    font-size: 16px;
    font-weight: 600;
    color: var(--ni-brand-blue);
    text-decoration: none;
    background: rgba(5, 191, 219, 0.08);
    padding: 10px 20px;
    border-radius: 100px;
    transition: all 0.3s ease;
  }

  .ni-ps-link:hover {
    background: var(--ni-brand-blue);
    color: white;
    transform: translateX(5px);
  }

  .ni-ps-arrow {
    margin-left: 8px;
    font-size: 18px;
  }

  /* Reveal Animation */
  .ni-ps-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .ni-ps-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Responsive */
  @media (max-width: 991px) {
    .ni-ps-row {
      gap: 40px;
    }
    .ni-ps-title-large { font-size: 34px; }
    .ni-ps-subtitle-highlight { font-size: 28px; }
  }

  @media (max-width: 767px) {
    .ni-ps-new { padding: 50px 0; }
    .ni-ps-row {
      flex-direction: column;
      gap: 30px;
      margin-bottom: 60px;
      text-align: center;
    }
    .ni-ps-row--solution {
      flex-direction: column-reverse;
    }
    .ni-ps-col--text {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .ni-ps-accent-line { margin: 0 auto; }
    .ni-ps-title-large { font-size: 30px; }
    .ni-ps-subtitle-highlight { font-size: 24px; }
    .ni-ps-footer-text { font-size: 20px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const observerOptions = {
      threshold: 0.2
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.ni-ps-reveal').forEach(el => observer.observe(el));
  });
</script>

{% schema %}
{
  "name": "Problem → Solution v2",
  "settings": [
    {
      "type": "header",
      "content": "The Problem Row"
    },
    {
      "type": "image_picker",
      "id": "problem_image",
      "label": "Problem Image"
    },
    {
      "type": "text",
      "id": "problem_title_1",
      "label": "Problem Title Line 1",
      "default": "Heat doesn't just feel uncomfortable."
    },
    {
      "type": "text",
      "id": "problem_title_2",
      "label": "Problem Title Line 2",
      "default": "It quietly takes control of your day."
    },
    {
      "type": "text",
      "id": "problem_footer",
      "label": "Problem Footer Text",
      "default": "Before you even notice."
    },
    {
      "type": "header",
      "content": "The Solution Row"
    },
    {
      "type": "image_picker",
      "id": "solution_image",
      "label": "Solution Image"
    },
    {
      "type": "text",
      "id": "solution_title",
      "label": "Solution Title",
      "default": "That's why we created Nano-ice."
    },
    {
      "type": "richtext",
      "id": "solution_description",
      "label": "Solution Description",
      "default": "<p>Designed to stay cool for <strong>up to 2 hours</strong>, giving you consistent relief instead of short bursts.</p><p>Worn around your neck, it cools <strong>key pulse points</strong> like the carotid arteries, where blood flow is higher, helping your body feel <strong>cooler for longer</strong>, even after you take it off.</p>"
    },
    {
      "type": "text",
      "id": "solution_link_text",
      "label": "Link Text",
      "default": "Learn about the science behind Nano-ice"
    },
    {
      "type": "url",
      "id": "solution_link",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "Problem → Solution v2"
    }
  ]
}
{% endschema %}
