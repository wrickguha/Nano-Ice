<!-- ============================================================
     NANO-ICE — Problem → Solution → How It Works
     Premium 3-column conversion section
     ============================================================ -->

<section class="ni-psw" id="ProblemSolution-{{ section.id }}">

  {%- comment -%} Decorative gradient blur shapes {%- endcomment -%}
  <div class="ni-psw__bg-blur ni-psw__bg-blur--1" aria-hidden="true"></div>
  <div class="ni-psw__bg-blur ni-psw__bg-blur--2" aria-hidden="true"></div>
  <div class="ni-psw__bg-blur ni-psw__bg-blur--3" aria-hidden="true"></div>

  <div class="page-width ni-psw__inner">

    {%- comment -%} Section Header {%- endcomment -%}
    {% if section.settings.section_heading != blank or section.settings.section_subheading != blank %}
      <div class="ni-psw__header">
        {% if section.settings.section_heading != blank %}
          <h2 class="ni-psw__title">{{ section.settings.section_heading | escape }}</h2>
        {% endif %}
        {% if section.settings.section_subheading != blank %}
          <p class="ni-psw__subtitle">{{ section.settings.section_subheading | escape }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ni-psw__grid">

      {%- comment -%} ─── COLUMN 1: THE PROBLEM ─── {%- endcomment -%}
      <div class="ni-psw__card ni-psw__card--problem ni-psw-reveal">
        <div class="ni-psw__card-inner">
          <span class="ni-psw__tag ni-psw__tag--problem">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            {{ section.settings.problem_tag | escape }}
          </span>
          <h3 class="ni-psw__heading ni-psw__heading--problem">Heat isn’t just uncomfortable. It’s limiting.</h3>
          <div class="ni-psw__problem-custom-content">
            <div>You feel it before anyone else does</div>
            <div>A simple walk doesn’t feel so simple</div>
            <div>Even the AC doesn’t help much</div>
            <div>Stepping outside feels harder than it should</div>
            <div class="ni-psw__problem-note">
              For people dealing with heat sensitivity, hot flashes, POTS, MS, or similar autoimmune conditions, this isn’t occasional. It affects how you plan your day, where you go, and how long you can stay out.<br>
              That’s why you need something that actually lasts and feels good to wear, because it looks as beautiful as it feels.
            </div>
          </div>
        </div>
        <div class="ni-psw__card-glow ni-psw__card-glow--problem" aria-hidden="true"></div>
      </div>

      {%- comment -%} ─── COLUMN 2: THE SOLUTION (hero card) ─── {%- endcomment -%}
      <div class="ni-psw__card ni-psw__card--solution ni-psw-reveal">
        <div class="ni-psw__card-inner">
          <span class="ni-psw__tag ni-psw__tag--solution">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {{ section.settings.solution_tag | escape }}
          </span>
          <h3 class="ni-psw__heading ni-psw__heading--solution">Finally, cooling that actually lasts.</h3>
          <div class="ni-psw__solution-custom-content">
            <div>Instead of constantly trying to manage the heat, you need something that works for longer. Most cooling products stop working within 30 to 60 minutes, leaving you right back where you started.</div>
            <div>Nano Ice is designed to stay cool for up to 2 hours, giving you consistent relief instead of short bursts. Worn around your neck, it cools key pulse points like the carotid arteries, where blood flow is higher, helping your body feel cooler for longer, even after you take it off.</div>
            <div>So you can stay comfortable, stay out longer, and move freely without planning everything around the heat.</div>
          </div>
        </div>
        <div class="ni-psw__card-glow ni-psw__card-glow--solution" aria-hidden="true"></div>
        <div class="ni-psw__card-ring" aria-hidden="true"></div>
      </div>


    </div><!-- /.ni-psw__grid -->
  </div><!-- /.page-width -->
</section>

<!-- ============================================================
     STYLES — Problem → Solution → How It Works
     ============================================================ -->
<style>
  /* ── Section ── */
  .ni-psw {
    position: relative;
    padding: 48px 0 56px;
    overflow: hidden;
    background: #f7fafc;
  }
  .ni-psw__bg-blur { display: none; }
  .ni-psw__inner { position: relative; z-index: 1; }

  /* ── Section header ── */
  .ni-psw__header {
    text-align: center;
    margin-bottom: 28px;
  }
  .ni-psw__title {
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    font-weight: 800;
    color: #111;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 6px;
  }
  .ni-psw__subtitle {
    font-size: 0.9rem;
    color: #6b7280;
    max-width: 440px;
    margin: 0 auto;
    line-height: 1.55;
  }

  /* ── Grid ── */
  .ni-psw__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    align-items: stretch;
  }

  /* ── Cards ── */
  .ni-psw__card {
    position: relative;
    border-radius: 14px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    display: flex;
    flex-direction: column;
  }
  .ni-psw__card:hover { transform: translateY(-4px); }

  .ni-psw__card-inner {
    position: relative;
    z-index: 1;
    padding: 22px 24px 24px;
    border-radius: 14px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Problem card */
  .ni-psw__card--problem .ni-psw__card-inner {
    background: #fff8f8;
    border: 1px solid rgba(239,68,68,0.15);
    box-shadow: 0 2px 12px rgba(239,68,68,0.06);
  }
  .ni-psw__card--problem:hover .ni-psw__card-inner {
    box-shadow: 0 8px 28px rgba(239,68,68,0.10);
  }

  /* Solution card */
  .ni-psw__card--solution .ni-psw__card-inner {
    background: #f0fbff;
    border: 1px solid rgba(5,191,219,0.18);
    box-shadow: 0 2px 12px rgba(5,191,219,0.07);
  }
  .ni-psw__card--solution:hover .ni-psw__card-inner {
    box-shadow: 0 8px 28px rgba(5,191,219,0.13);
  }

  /* Remove decorative overlays */
  .ni-psw__card-glow,
  .ni-psw__card-ring { display: none; }

  /* ── Tag pills ── */
  .ni-psw__tag {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    padding: 3px 9px;
    border-radius: 100px;
    margin-bottom: 10px;
    width: fit-content;
  }
  .ni-psw__tag svg { width: 12px; height: 12px; }
  .ni-psw__tag--problem { background: rgba(239,68,68,0.09); color: #DC2626; }
  .ni-psw__tag--solution { background: rgba(5,191,219,0.10); color: #0891B2; }

  /* ── Card headings ── */
  .ni-psw__heading {
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
    color: #111;
  }

  /* ── Problem bullets ── */
  .ni-psw__problem-custom-content {
    font-size: 0.82rem;
    line-height: 1.55;
    color: #374151;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .ni-psw__problem-custom-content > div:not(.ni-psw__problem-note) {
    padding: 6px 0 6px 14px;
    border-left: 2px solid rgba(239,68,68,0.35);
    margin-bottom: 5px;
    font-size: 0.82rem;
    color: #374151;
  }
  .ni-psw__problem-custom-content > div:not(.ni-psw__problem-note):last-of-type {
    margin-bottom: 0;
  }

  /* ── Problem note paragraph ── */
  .ni-psw__problem-note {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid rgba(239,68,68,0.12);
    font-size: 0.78rem;
    color: #6b7280;
    line-height: 1.6;
    border-left: none !important;
    padding-left: 0 !important;
  }

  /* ── Solution paragraphs ── */
  .ni-psw__solution-custom-content {
    font-size: 0.9rem;
    line-height: 1.55;
    color: #374151;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ni-psw__solution-custom-content > div {
    padding-left: 12px;
    border-left: 2px solid rgba(5,191,219,0.4);
    font-size: 0.9rem;
  }

  /* ── Scroll-reveal ── */
  .ni-psw-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ni-psw-reveal.ni-psw-visible { opacity: 1; transform: translateY(0); }
  .ni-psw__card--solution.ni-psw-reveal { transition-delay: 0.1s; }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .ni-psw { padding: 36px 0 44px; }
    .ni-psw__grid { grid-template-columns: 1fr; gap: 16px; }
    .ni-psw__header { margin-bottom: 22px; }
    .ni-psw__card-inner { padding: 18px 18px 20px; }
  }
</style>

<!-- ── Scroll-reveal observer ── -->
<script>
  (function() {
    var els = document.querySelectorAll('#ProblemSolution-{{ section.id }} .ni-psw-reveal');
    if (!els.length) return;
    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) {
            e.target.classList.add('ni-psw-visible');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
      els.forEach(function(el) { obs.observe(el); });
    } else {
      els.forEach(function(el) { el.classList.add('ni-psw-visible'); });
    }
  })();
</script>

