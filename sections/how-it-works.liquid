<div class="how-it-works">
  <div class="page-width">
    
    <div class="section-header text-center">
      <h2>How It Works</h2>
      <p>From selection to delivery — effortless elegance in just a few steps.</p>
    </div>

    <div class="how-steps">

      <div class="step ni-animate">
        <div class="step-number">1</div>
        <div class="icon">❄️</div>
        <h4>Browse Collection</h4>
        <p>Explore our curated ice-cool products designed to keep you cool all day.</p>
      </div>

      <div class="step ni-animate">
        <div class="step-number">2</div>
        <div class="icon">🎯</div>
        <h4>Choose Your Item</h4>
        <p>Select the perfect cooling product that suits your style and needs.</p>
      </div>

      <div class="step ni-animate">
        <div class="step-number">3</div>
        <div class="icon">💎</div>
        <h4>Enjoy Quality</h4>
        <p>Experience premium cooling products crafted for comfort and style.</p>
      </div>

    </div>

  </div>
</div>

